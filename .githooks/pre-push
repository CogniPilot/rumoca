#!/usr/bin/env bash
# Pre-push hook: CI-mirroring local verification, excluding only the slow 180-model MSL parity job.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Git passes ref update records on stdin to pre-push hooks. None of the local
# verification commands consume that stream, and inheriting it can perturb test
# processes that probe stdin.
exec </dev/null

required_toolchain="$(sed -n 's/^channel = "\(.*\)"/\1/p' rust-toolchain.toml | head -n 1)"
active_toolchain="$(rustup show active-toolchain 2>/dev/null | awk '{print $1}')"
if [[ -n "$required_toolchain" && "$active_toolchain" != "$required_toolchain"* ]]; then
  echo "pre-push: active toolchain '$active_toolchain' does not match required '$required_toolchain'."
  echo "pre-push: run 'rustup override set $required_toolchain' in this repository."
  exit 1
fi

echo "pre-push: checking Rust file line counts across workspace..."
cargo run --quiet --bin rum -- repo policy rust-file-lines --all-files

echo "pre-push: enforcing traversal policy..."
cargo run --quiet --bin rumoca-traversal-policy-check

echo "pre-push: running verify quick command (CI mirror without MSL parity)..."
cargo run --bin rum -- verify quick

echo "pre-push checks passed."
