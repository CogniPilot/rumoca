{
  "model": "{{ model_name | default("model") }}",
  "kernel": "derivative_rhs",
  "workgroup_size": 64,
  "rows": {{ solve_blocks.continuous.derivative_rhs.output_count }},
  "y_len": {{ solve.layout.y_scalars }},
  "p_len": {{ solve.layout.p_scalars }},
  "runtime_event_roots": {{ solve.events.root_conditions.programs | length }},
  "scheduled_time_events": {{ solve.events.scheduled_time_events | length }},
  "discrete_update_rows": {{ solve.discrete.rhs.programs | length }},
  "bindings": {
{%- for name, slot in solve.layout.bindings | items %}
    "{{ name }}": {% if slot.Y is defined %}{ "kind": "y", "index": {{ slot.Y.index }} }{% elif slot.P is defined %}{ "kind": "p", "index": {{ slot.P.index }} }{% elif slot.Constant is defined %}{ "kind": "constant", "value": {{ slot.Constant }} }{% else %}{ "kind": "time" }{% endif %}{{ "," if not loop.last }}
{%- endfor %}
  }
}
