// Generated by Rumoca.
//
// WGSL Solve-IR derivative kernel (readiness level 0). One compute
// invocation evaluates one derivative row from the Solve-IR scalar
// fallback programs; tensor-native kernels belong in this target once
// equivalence tests against the prepared interpreter exist.
//
// Precision note: WGSL baseline is f32; reference solvers integrate in
// f64. Expect single-precision drift on long horizons.
{%- set name = model_name | default("model") | sanitize %}
{%- set derivative = solve_blocks.continuous.derivative_rhs %}
{%- set rows = derivative.scalar_programs.programs %}

// model: {{ name }}
const ROWS: u32 = {{ rows | length }}u;
const Y_LEN: u32 = {{ solve.layout.y_scalars }}u;
const P_LEN: u32 = {{ solve.layout.p_scalars }}u;

struct Uniforms {
    time: f32,
    _pad0: f32,
    _pad1: f32,
    _pad2: f32,
}

@group(0) @binding(0) var<storage, read> y: array<f32>;
@group(0) @binding(1) var<storage, read> p: array<f32>;
@group(0) @binding(2) var<storage, read_write> out: array<f32>;
@group(0) @binding(3) var<uniform> u: Uniforms;

@compute @workgroup_size(64)
fn derivative_rhs(@builtin(global_invocation_id) gid: vec3<u32>) {
    let row = gid.x;
    if (row >= ROWS) {
        return;
    }
    // Keep every binding in the auto layout even when a model does not use
    // it, so host drivers can bind a fixed group shape.
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
{%- set cfg = {"time": "u.time", "y": "y[{}]", "p": "p[{}]"} %}
    switch row {
{%- for row in rows %}
        case {{ loop.index0 }}u: {
            out[{{ loop.index0 }}] = {{ render_solve_row_wgsl(row, cfg) }};
        }
{%- endfor %}
        default: {
        }
    }
}

