// Generated by Rumoca.
//
// WGSL Solve-IR derivative kernels (readiness level 0). Affine row
// families (stencils) render as one parametric kernel each; remaining
// rows render as switch chunks. Tensor-native nodes belong in this
// target once equivalence tests against the prepared interpreter exist.
//
// Precision note: WGSL baseline is f32; reference solvers integrate in
// f64. Expect single-precision drift on long horizons.
{%- set name = model_name | default("model") | sanitize %}
{%- set derivative = solve_blocks.continuous.derivative_rhs %}
{%- set rows = derivative.scalar_programs.programs %}
{%- set stencils = derivative.stencils %}
{%- set residual = derivative.stencil_residual_rows %}

// model: {{ name }}
const ROWS: u32 = {{ rows | length }}u;
const Y_LEN: u32 = {{ solve.layout.y_scalars }}u;
const P_LEN: u32 = {{ solve.layout.p_scalars }}u;

struct Uniforms {
    time: f32,
    _pad0: f32,
    _pad1: f32,
    _pad2: f32,
}

@group(0) @binding(0) var<storage, read> y: array<f32>;
@group(0) @binding(1) var<storage, read> p: array<f32>;
@group(0) @binding(2) var<storage, read_write> out: array<f32>;
@group(0) @binding(3) var<uniform> u: Uniforms;
{%- set cfg = {"time": "u.time", "y": "y[{}]", "p": "p[{}]"} %}
{%- set chunk_size = 64 %}
{%- for st in stencils %}

// Stencil family: rows {{ st.start_row }}..{{ st.start_row + st.count }}.
@compute @workgroup_size(64)
fn derivative_rhs_stencil{{ loop.index0 }}(@builtin(global_invocation_id) gid: vec3<u32>) {
    let r = gid.x;
    if (r >= {{ st.count }}u) {
        return;
    }
    // Keep every binding in the auto layout even when a kernel does not
    // use it, so host drivers can bind one fixed group shape.
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
    out[{{ st.start_row }}u + r] = {{ render_solve_stencil_wgsl(st, cfg) }};
}
{%- endfor %}
{%- for start in range(0, residual | length, chunk_size) %}

@compute @workgroup_size(64)
fn derivative_rhs_chunk{{ loop.index0 }}(@builtin(global_invocation_id) gid: vec3<u32>) {
    let slot = {{ start }}u + gid.x;
    if (slot >= {{ [start + chunk_size, residual | length] | min }}u) {
        return;
    }
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
    switch slot {
{%- for slot_index in range(start, [start + chunk_size, residual | length] | min) %}
{%- set row_index = residual[slot_index] %}
        case {{ slot_index }}u: {
            out[{{ row_index }}] = {{ render_solve_row_wgsl(rows[row_index], cfg) }};
        }
{%- endfor %}
        default: {
        }
    }
}
{%- endfor %}
{%- if (stencils | length) == 0 and (residual | length) == 0 %}

@compute @workgroup_size(64)
fn derivative_rhs_chunk0(@builtin(global_invocation_id) gid: vec3<u32>) {
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
    _ = arrayLength(&out);
    _ = gid.x;
}
{%- endif %}

