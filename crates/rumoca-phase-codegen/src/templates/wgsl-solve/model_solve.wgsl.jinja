// Generated by Rumoca.
//
// WGSL Solve-IR kernels. Native tensor families render as one parametric
// kernel each; remaining scalar fallback rows render as switch chunks.
//
// Precision note: WGSL baseline is f32; reference solvers integrate in
// f64. Expect single-precision drift on long horizons.
{%- set name = model_name | default("model") | sanitize %}
{%- set derivative = solve_blocks.continuous.derivative_rhs %}
{%- set rows = derivative.scalar_programs.programs %}
{%- set native_families = derivative.native_families %}
{%- set fallback = derivative.scalar_fallback_rows %}
{%- set implicit = solve_blocks.continuous.implicit_rhs %}
{%- set implicit_rows = implicit.scalar_programs.programs %}
{%- set implicit_native_families = implicit.native_families %}
{%- set implicit_fallback = implicit.scalar_fallback_rows %}
{%- set workgroup_size = 64 %}
{%- set fallback_chunks = ((fallback | length + workgroup_size - 1) // workgroup_size) if fallback | length > 0 else 0 %}
{%- set derivative_kernel_count = ((native_families | length) + fallback_chunks) if (native_families | length) > 0 or fallback | length > 0 else 1 %}
{%- set implicit_fallback_chunks = ((implicit_fallback | length + workgroup_size - 1) // workgroup_size) if implicit_fallback | length > 0 else 0 %}
{%- set implicit_kernel_count = (implicit_native_families | length) + implicit_fallback_chunks %}

// model: {{ name }}
const ROWS: u32 = {{ derivative.output_count }}u;
const IMPLICIT_RHS_ROWS: u32 = {{ implicit.output_count }}u;
const Y_LEN: u32 = {{ solve.layout.y_scalars }}u;
const P_LEN: u32 = {{ solve.layout.p_scalars }}u;

struct Uniforms {
    time: f32,
    _pad0: f32,
    _pad1: f32,
    _pad2: f32,
}

@group(0) @binding(0) var<storage, read> y: array<f32>;
@group(0) @binding(1) var<storage, read> p: array<f32>;
@group(0) @binding(2) var<storage, read_write> out: array<f32>;
@group(0) @binding(3) var<uniform> u: Uniforms;
{%- set cfg = {"time": "u.time", "y": "y[{}]", "p": "p[{}]"} %}
{%- set chunk_size = workgroup_size %}
{%- for st in native_families %}

// Native {{ st.kind }} family: affine output map start {{ render_solve_native_family_output_map_start(st) }}, rows {{ st.count }}.
@compute @workgroup_size({{ workgroup_size }})
fn derivative_rhs_{{ st.kind }}{{ loop.index0 }}(@builtin(global_invocation_id) gid: vec3<u32>) {
    let r = gid.x;
    if (r >= {{ st.count }}u) {
        return;
    }
    // Keep every binding in the auto layout even when a kernel does not
    // use it, so host drivers can bind one fixed group shape.
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
    out[{{ render_solve_native_family_output_index_wgsl(st) }}] = {{ render_solve_native_family_wgsl(st, cfg) }};
}
{%- endfor %}
{%- for start in range(0, fallback | length, chunk_size) %}

@compute @workgroup_size({{ workgroup_size }})
fn derivative_rhs_chunk{{ loop.index0 }}(@builtin(global_invocation_id) gid: vec3<u32>) {
    let slot = {{ start }}u + gid.x;
    if (slot >= {{ [start + chunk_size, fallback | length] | min }}u) {
        return;
    }
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
    switch slot {
{%- for slot_index in range(start, [start + chunk_size, fallback | length] | min) %}
{%- set fallback_row = fallback[slot_index] %}
{%- set row_index = fallback_row.row_index %}
        case {{ slot_index }}u: {
            out[{{ fallback_row.output_index }}] = {{ render_solve_row_output_wgsl(rows[row_index], fallback_row.output_ordinal, cfg) }};
        }
{%- endfor %}
        default: {
        }
    }
}
{%- endfor %}
{%- if (native_families | length) == 0 and (fallback | length) == 0 %}

@compute @workgroup_size({{ workgroup_size }})
fn derivative_rhs_chunk0(@builtin(global_invocation_id) gid: vec3<u32>) {
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
    _ = arrayLength(&out);
    _ = gid.x;
}
{%- endif %}
{%- for st in implicit_native_families %}

// Native implicit RHS {{ st.kind }} family: affine output map start {{ render_solve_native_family_output_map_start(st) }}, rows {{ st.count }}.
@compute @workgroup_size({{ workgroup_size }})
fn implicit_rhs_{{ st.kind }}{{ loop.index0 }}(@builtin(global_invocation_id) gid: vec3<u32>) {
    let r = gid.x;
    if (r >= {{ st.count }}u) {
        return;
    }
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
    out[{{ render_solve_native_family_output_index_wgsl(st) }}] = {{ render_solve_native_family_wgsl(st, cfg) }};
}
{%- endfor %}
{%- for start in range(0, implicit_fallback | length, chunk_size) %}

@compute @workgroup_size({{ workgroup_size }})
fn implicit_rhs_chunk{{ loop.index0 }}(@builtin(global_invocation_id) gid: vec3<u32>) {
    let slot = {{ start }}u + gid.x;
    if (slot >= {{ [start + chunk_size, implicit_fallback | length] | min }}u) {
        return;
    }
    _ = u.time;
    _ = arrayLength(&y);
    _ = arrayLength(&p);
    switch slot {
{%- for slot_index in range(start, [start + chunk_size, implicit_fallback | length] | min) %}
{%- set fallback_row = implicit_fallback[slot_index] %}
{%- set row_index = fallback_row.row_index %}
        case {{ slot_index }}u: {
            out[{{ fallback_row.output_index }}] = {{ render_solve_row_output_wgsl(implicit_rows[row_index], fallback_row.output_ordinal, cfg) }};
        }
{%- endfor %}
        default: {
        }
    }
}
{%- endfor %}

