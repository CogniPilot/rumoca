def _linsolve_component(matrix, rhs, n, component):
	"""Solve A x = b (A row-major n*n) and return x[component]; symbolic-safe."""
	A = ca.reshape(ca.vertcat(*matrix), n, n).T
	b = ca.vertcat(*rhs)
	return ca.solve(A, b)[component]


