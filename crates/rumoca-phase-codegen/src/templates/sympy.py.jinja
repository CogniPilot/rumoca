{%- set cfg = {
  "modelica_builtins": true,
  "if_style": "function",
  "sanitize_dots": true,
  "python_range": true,
  "and_op": "sp.And",
  "or_op": "sp.Or",
  "not_op": "sp.Not"
} -%}
{%- macro symbol_expr(name, var) -%}
{% if var.dims is defined and var.dims | length > 0 -%}
sp.IndexedBase("{{ name }}")
{%- else -%}
sp.Symbol("{{ name }}")
{%- endif %}
{%- endmacro %}
{%- macro declare_vector(attr, group) -%}
{% if group | length > 0 %}
{% for name, var in group | items %}
        {{ name | sanitize }} = {{ symbol_expr(name, var) }}
{% if var.dims is defined and var.dims | length == 1 %}
{% for i in range(1, var.dims[0] + 1) %}
        {{ (name ~ "[" ~ i ~ "]") | sanitize }} = {{ name | sanitize }}[{{ i }}]
{% endfor %}
{% endif %}
{% endfor %}
        self.{{ attr }}, self.{{ attr }}_start, self.{{ attr }}_index = _vector([
{%- for name, var in group | items %}
            ("{{ name }}", {{ name | sanitize }}, {% if var.start is not none %}{{ render_expr(var.start, cfg) }}{% else %}None{% endif %}){{ "," if not loop.last }}
{%- endfor %}
        ])
{% else %}
        self.{{ attr }}, self.{{ attr }}_start, self.{{ attr }}_index = _vector([])
{% endif %}
{%- endmacro %}
{%- macro render_residual(eq) -%}
{%- if eq.lhs is defined and eq.lhs is not none -%}
{%- if eq.rhs is defined and eq.rhs.Binary is defined and eq.rhs.Binary.lhs is defined -%}
({{ render_expr(eq.rhs.Binary.lhs, cfg) }} - ({{ render_expr(eq.rhs, cfg) }}))
{%- else -%}
({{ eq.lhs | sanitize }} - ({{ render_expr(eq.rhs, cfg) }}))
{%- endif -%}
{%- else -%}
{{ render_expr(eq.rhs, cfg) }}
{%- endif -%}
{%- endmacro %}
{%- macro render_explicit_target(eq) -%}
{%- if eq.rhs is defined and eq.rhs.Binary is defined and eq.rhs.Binary.lhs is defined -%}
{{ render_expr(eq.rhs.Binary.lhs, cfg) }}
{%- elif eq.lhs is defined and eq.lhs is not none -%}
{{ eq.lhs | sanitize }}
{%- endif -%}
{%- endmacro %}
"""
Generated by Rumoca.

This template renders the current DAE context into a SymPy-friendly symbolic
model. It keeps Rumoca's continuous equations in residual form and can solve
for explicit state derivatives and algebraics when possible.
"""

import sympy as sp


def der(symbol):
    if isinstance(symbol, sp.Indexed):
        return sp.IndexedBase(f"{symbol.base}_dot")[symbol.indices]
    if isinstance(symbol, sp.IndexedBase):
        return sp.IndexedBase(f"{symbol}_dot")
    return sp.Symbol(f"{symbol}_dot")


def pre(symbol):
    if isinstance(symbol, sp.Indexed):
        return sp.IndexedBase(f"pre_{symbol.base}")[symbol.indices]
    if isinstance(symbol, sp.IndexedBase):
        return sp.IndexedBase(f"pre_{symbol}")
    return sp.Symbol(f"pre_{symbol}")


def if_else(condition, then_expr, else_expr):
    return sp.Piecewise((then_expr, condition), (else_expr, True))


def _vector(entries):
    return (
        sp.Matrix([symbol for _, symbol, _ in entries]),
        {name: start for name, _, start in entries},
        {name: index for index, (name, _, _) in enumerate(entries)},
    )


def _column(entries):
    return sp.Matrix(entries) if entries else sp.Matrix([])


def zeros(*dims):
    if len(dims) == 1:
        return sp.Matrix.zeros(int(dims[0]), 1)
    return sp.Matrix.zeros(*(int(dim) for dim in dims))


def ones(*dims):
    if len(dims) == 1:
        return sp.Matrix.ones(int(dims[0]), 1)
    return sp.Matrix.ones(*(int(dim) for dim in dims))


def sum(values):
    if isinstance(values, sp.MatrixBase):
        return sp.Add(*list(values))
    if isinstance(values, (list, tuple)):
        return sp.Add(*values)
    return values


abs = sp.Abs
min = sp.Min
max = sp.Max
sign = sp.sign
sqrt = sp.sqrt
sin = sp.sin
cos = sp.cos
tan = sp.tan
asin = sp.asin
acos = sp.acos
atan = sp.atan
atan2 = sp.atan2
sinh = sp.sinh
cosh = sp.cosh
tanh = sp.tanh
exp = sp.exp
log = sp.log
log10 = lambda value: sp.log(value, 10)
floor = sp.floor
ceil = sp.ceiling
transpose = lambda value: sp.Matrix(value).T
identity = sp.eye
cross = lambda lhs, rhs: sp.Matrix(lhs).cross(sp.Matrix(rhs))
div = lambda lhs, rhs: sp.floor(lhs / rhs)
mod = sp.Mod
rem = sp.Mod


class Model:
    """Flattened symbolic DAE model."""

    def __init__(self):
        self.time = sp.Symbol("time")
        time = self.time

        # States, algebraics, inputs, outputs, parameters, constants, discretes.
{{ declare_vector("x", dae.x) }}
{{ declare_vector("y", dae.y) }}
{{ declare_vector("u", dae.u) }}
{{ declare_vector("w", dae.w) }}
{{ declare_vector("p", dae.p) }}
{{ declare_vector("constants", dae.constants) }}
{{ declare_vector("z", dae.z) }}
{{ declare_vector("m", dae.m) }}
{{ declare_vector("x_dot_alias", dae.x_dot_alias) }}
        self.f_x = {% if dae.f_x | length > 0 %}_column([
{%- for eq in dae.f_x %}
            {{ render_residual(eq) }}{{ "," if not loop.last }}
{%- endfor %}
        ]){% else %}_column([]){% endif %}

        self.initial_residuals = {% if dae.initial_equations | length > 0 %}_column([
{%- for eq in dae.initial_equations %}
            {{ render_residual(eq) }}{{ "," if not loop.last }}
{%- endfor %}
        ]){% else %}_column([]){% endif %}

        self.relations = {% if dae.relation | length > 0 %}_column([
{%- for expr in dae.relation %}
            {{ render_expr(expr, cfg) }}{{ "," if not loop.last }}
{%- endfor %}
        ]){% else %}_column([]){% endif %}

        self.explicit_targets = [
{%- for eq in dae.f_x %}
{% if (eq.lhs is defined and eq.lhs is not none) or (eq.rhs is defined and eq.rhs.Binary is defined and eq.rhs.Binary.lhs is defined) %}
            {{ render_explicit_target(eq) }},
{% endif %}
{%- endfor %}
        ]
        self.explicit_solution = None
        self.explicit_rhs = sp.Matrix([])

    def solve_explicit(self):
        """Best-effort symbolic solve for explicit derivatives and algebraics."""
        if len(self.f_x) == 0 or len(self.explicit_targets) == 0:
            self.explicit_solution = {}
            self.explicit_rhs = sp.Matrix([])
            return self.explicit_solution

        solutions = sp.solve(
            list(self.f_x),
            self.explicit_targets,
            dict=True,
            simplify=False,
        )
        self.explicit_solution = solutions[0] if solutions else {}
        self.explicit_rhs = sp.Matrix(
            [
                self.explicit_solution.get(symbol, symbol)
                for symbol in self.explicit_targets
            ]
        )
        return self.explicit_solution

    def summary(self):
        return {
            "states": [str(symbol) for symbol in self.x],
            "algebraics": [str(symbol) for symbol in self.y],
            "inputs": [str(symbol) for symbol in self.u],
            "parameters": [str(symbol) for symbol in self.p],
            "continuous_residual_count": len(self.f_x),
            "initial_residual_count": len(self.initial_residuals),
            "explicit_target_count": len(self.explicit_targets),
        }


if __name__ == "__main__":
    model = Model()
    print(model.summary())
    if len(model.f_x) > 0 and len(model.explicit_targets) > 0:
        print(model.solve_explicit())
