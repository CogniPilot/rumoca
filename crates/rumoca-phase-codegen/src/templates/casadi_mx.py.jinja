    print(f"  Inputs: {dae_fn.name_in()}")
    print(f"  Outputs: {dae_fn.name_out()}")

    # Verify differentiability
    if model['n_x'] > 0:
        J = dae_fn.jacobian()
        print(f"\nJacobian computable: {J}")

    # Quick simulation demo
    if model['n_x'] > 0:
        ts, xs = simulate()
        print(f"\nSimulated {len(ts)} steps, final state: {xs[:, -1]}")
