    _p0_parts.append(_flat_start(
        {% if var.start %}{{ render_expr(var.start, cfg) }}{% else %}0.0{% endif %},
        {% if var.dims %}{{ var.dims | product }}{% else %}1{% endif %},
        '{{ name }}'
    ))
{%- endfor %}
    p0 = np.concatenate(_p0_parts) if _p0_parts else np.array([])

    # Algebraic initial guesses (continuous y, w then discrete z, m)
    _z0_parts = []
{%- for name, var in dae.y | items %}
    _z0_parts.append(_flat_start(
        {% if var.start %}{{ render_expr(var.start, cfg) }}{% else %}0.0{% endif %},
        {% if var.dims %}{{ var.dims | product }}{% else %}1{% endif %},
        '{{ name }}'
    ))
{%- endfor %}
{%- for name, var in dae.w | items %}
    _z0_parts.append(_flat_start(
        {% if var.start %}{{ render_expr(var.start, cfg) }}{% else %}0.0{% endif %},
        {% if var.dims %}{{ var.dims | product }}{% else %}1{% endif %},
        '{{ name }}'
    ))
{%- endfor %}
{%- for name, var in dae.z | items %}
    _z0_parts.append(_flat_start(
        {% if var.start %}{{ render_expr(var.start, cfg) }}{% else %}0.0{% endif %},
        {% if var.dims %}{{ var.dims | product }}{% else %}1{% endif %},
        '{{ name }}'
    ))
{%- endfor %}
{%- for name, var in dae.m | items %}
    _z0_parts.append(_flat_start(
        {% if var.start %}{{ render_expr(var.start, cfg) }}{% else %}0.0{% endif %},
        {% if var.dims %}{{ var.dims | product }}{% else %}1{% endif %},
        '{{ name }}'
    ))
{%- endfor %}
    z0 = np.concatenate(_z0_parts) if _z0_parts else np.array([])

    return {
        'name': 'Model',
        't': t,
        'x': _x,
        'xdot': _xdot,
        'z': _z,
        'u': _u,
        'p': _p,
        'f_x': f_x,
        'dae_fn': dae_fn,
        'build_integrator': build_integrator,
{%- if dae.initial_equations | length > 0 %}
        'init_fn': init_fn,
{%- endif %}
{%- if dae.relation | length > 0 %}
        'zero_crossings': zero_crossings,
{%- endif %}
{%- if dae.functions | length > 0 %}
        'functions': { {%- for func_name, func in dae.functions | items %}{%- if has_complex_params(func) != "yes" and func_name != "Complex" %}'{{ func_name | sanitize }}': {{ func_name | sanitize }}, {%- endif %}{%- endfor %} },
{%- endif %}
        'x0': x0,
        'p0': p0,
        'z0': z0,
        'n_x': n_x,
        'n_z': n_z,
        'n_z_continuous': n_z_continuous,
        'n_u': n_u,
        'n_p': n_p,
        'state_names': [{% for name, var in dae.x | items %}'{{ name }}'{{ ", " if not loop.last else "" }}{% endfor %}],
        'algebraic_names': [{% for name, var in dae.y | items %}'{{ name }}', {% endfor %}{% for name, var in dae.w | items %}'{{ name }}'{{ ", " if not loop.last else "" }}{% endfor %}],
        'input_names': [{% for name, var in dae.u | items %}'{{ name }}'{{ ", " if not loop.last else "" }}{% endfor %}],
        'param_names': [{% for name, var in dae.p | items %}'{{ name }}'{{ ", " if not loop.last else "" }}{% endfor %}],
    }


