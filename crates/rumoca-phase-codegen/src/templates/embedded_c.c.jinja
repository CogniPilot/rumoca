    m->u[{{ ns_idx.offset }}] = {% if var.start %}{{ render_expr(var.start, cfg) }}{% else %}REAL_C(0.0){% endif %};  /* {{ name }} */
{% set ns_idx.offset = ns_idx.offset + 1 %}
{% endif %}
{% endfor %}

    /* Compute initial algebraics and outputs */
    {{ model_name }}_compute_algebraics(m, REAL_C(0.0));
}

/* =========================================================================
 * RK4 fixed-step integrator
 * ========================================================================= */
static void {{ model_name }}_step({{ model_name }}_t* m, real_t t, real_t dt) {
{% if n_x > 0 %}
    real_t k1[MODEL_N_X];
    real_t k2[MODEL_N_X];
    real_t k3[MODEL_N_X];
    real_t k4[MODEL_N_X];
    real_t x_tmp[MODEL_N_X];

    /* Save original state */
    real_t x_save[MODEL_N_X];
    for (int i = 0; i < MODEL_N_X; i++) { x_save[i] = m->x[i]; }

    /* k1 = f(t, x) */
    {{ model_name }}_compute_algebraics(m, t);
    {{ model_name }}_derivatives(m, t, k1);

    /* k2 = f(t + dt/2, x + dt/2 * k1) */
    for (int i = 0; i < MODEL_N_X; i++) {
        x_tmp[i] = x_save[i] + REAL_C(0.5) * dt * k1[i];
        m->x[i] = x_tmp[i];
    }
    {{ model_name }}_compute_algebraics(m, t + REAL_C(0.5) * dt);
    {{ model_name }}_derivatives(m, t + REAL_C(0.5) * dt, k2);

    /* k3 = f(t + dt/2, x + dt/2 * k2) */
    for (int i = 0; i < MODEL_N_X; i++) {
        x_tmp[i] = x_save[i] + REAL_C(0.5) * dt * k2[i];
        m->x[i] = x_tmp[i];
    }
    {{ model_name }}_compute_algebraics(m, t + REAL_C(0.5) * dt);
    {{ model_name }}_derivatives(m, t + REAL_C(0.5) * dt, k3);

    /* k4 = f(t + dt, x + dt * k3) */
    for (int i = 0; i < MODEL_N_X; i++) {
        x_tmp[i] = x_save[i] + dt * k3[i];
        m->x[i] = x_tmp[i];
    }
    {{ model_name }}_compute_algebraics(m, t + dt);
    {{ model_name }}_derivatives(m, t + dt, k4);

    /* x_new = x + (dt/6)(k1 + 2*k2 + 2*k3 + k4) */
    for (int i = 0; i < MODEL_N_X; i++) {
        m->x[i] = x_save[i] + (dt / REAL_C(6.0)) * (k1[i] + REAL_C(2.0) * k2[i] + REAL_C(2.0) * k3[i] + k4[i]);
    }
{% endif %}

    /* Update algebraics and outputs at new state */
    {{ model_name }}_compute_algebraics(m, t + dt);
}
