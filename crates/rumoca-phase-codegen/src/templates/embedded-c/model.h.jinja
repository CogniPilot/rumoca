{#- Embedded C header over prepared Solve IR. -#}
{%- if ir_kind != "solve" -%}
{{ fail("embedded-c target requires Solve IR") }}
{%- endif -%}
{%- set model_name = model_name | default("model") | sanitize -%}
{%- set y_len = solve.layout.y_scalars -%}
{%- set p_len = solve.layout.p_scalars -%}
{%- set derivative_len = solve_blocks.continuous.derivative_rhs.output_count -%}
{%- set root_len = solve.events.root_conditions.programs | length if solve.events is defined and solve.events.root_conditions is defined else 0 -%}
{%- set periodic_events = solve.clocks.periodic_event_schedules if solve.clocks is defined and solve.clocks.periodic_event_schedules is defined else [] -%}
{%- set periodic_len = periodic_events | length -%}
#pragma once

#include <stddef.h>

typedef double real_t;

enum {
    {{ model_name | upper }}_Y_LEN = {{ y_len }},
    {{ model_name | upper }}_P_LEN = {{ p_len }},
    {{ model_name | upper }}_STATE_LEN = {{ solve.solve_layout.state_scalar_count }},
    {{ model_name | upper }}_DERIVATIVE_LEN = {{ derivative_len }},
    {{ model_name | upper }}_EVENT_INDICATOR_LEN = {{ root_len }},
    {{ model_name | upper }}_PERIODIC_EVENT_LEN = {{ periodic_len }}
};

/* Named Solve slots. Array symbols point at the first scalar slot and define
 * *_LEN for the contiguous scalar span; indexed symbols have length 1.
 */
{%- for sym in solve_symbols %}
#define {{ sym.macro_name }} {{ sym.index }} /* {{ sym.kind | lower }}[{{ sym.index }}]: {{ sym.name }} */
{%- if sym.length > 1 %}
#define {{ sym.macro_name }}_LEN {{ sym.length }}
{%- endif %}
{%- endfor %}

typedef enum {
    {{ model_name | upper }}_SLOT_Y = 0,
    {{ model_name | upper }}_SLOT_P = 1
} {{ model_name }}_slot_kind_t;

typedef struct {
    const char *name;
    {{ model_name }}_slot_kind_t kind;
    int index;
    int length;
} {{ model_name }}_symbol_t;

extern const {{ model_name }}_symbol_t {{ model_name }}_symbols[];
extern const size_t {{ model_name }}_symbol_count;

typedef struct {
    real_t time;
    real_t y[{{ y_len if y_len > 0 else 1 }}];
    real_t p[{{ p_len if p_len > 0 else 1 }}];
    real_t event_indicators[{{ root_len if root_len > 0 else 1 }}];
    real_t event_indicators_prev[{{ root_len if root_len > 0 else 1 }}];
    real_t next_periodic_event[{{ periodic_len if periodic_len > 0 else 1 }}];
} {{ model_name }}_t;

static inline real_t {{ model_name }}_get_y(const {{ model_name }}_t *m, int index) {
    return (m && index >= 0 && index < {{ model_name | upper }}_Y_LEN) ? m->y[index] : 0.0;
}

static inline real_t {{ model_name }}_get_p(const {{ model_name }}_t *m, int index) {
    return (m && index >= 0 && index < {{ model_name | upper }}_P_LEN) ? m->p[index] : 0.0;
}

static inline void {{ model_name }}_set_y({{ model_name }}_t *m, int index, real_t value) {
    if (m && index >= 0 && index < {{ model_name | upper }}_Y_LEN) {
        m->y[index] = value;
    }
}

static inline void {{ model_name }}_set_p({{ model_name }}_t *m, int index, real_t value) {
    if (m && index >= 0 && index < {{ model_name | upper }}_P_LEN) {
        m->p[index] = value;
    }
}

void startup({{ model_name }}_t *m);
void dostep({{ model_name }}_t *m, real_t dt);
void recalibrate({{ model_name }}_t *m);
void {{ model_name }}_sync_pre({{ model_name }}_t *m);
