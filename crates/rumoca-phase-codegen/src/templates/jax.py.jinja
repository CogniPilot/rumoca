def simulate_csv(t_end=1.0, dt=0.01):
    """Run simulation and return CSV string."""
    ts, ys = simulate(t_span=(0.0, t_end), dt=dt)
    header = "time," + ",".join(get_state_names())
    rows = [header]
    for i in range(len(ts)):
        row = [f"{float(ts[i]):.10g}"] + [f"{float(ys[i, j]):.10g}" for j in range(ys.shape[1])]
        rows.append(",".join(row))
    return "\n".join(rows)


