def simulate(x0=None, t_span=(0.0, 1.0), dt=0.01):
    """Simulate the model.

    Args:
        x0: Initial state as JAX array (uses defaults if None)
        t_span: Tuple of (t0, tf)
        dt: Integration step size

    Returns:
        Tuple of (times, states)
    """
    defaults = get_default_values()

    if x0 is None:
        y0 = jnp.array(defaults['x0'])
    else:
        y0 = jnp.asarray(x0)

    params = jnp.array(defaults['p0'])

    # Merge constants and discrete vars into a single dict
    cd = {}
    cd.update(defaults['constants'])
    cd.update(defaults['z0'])
    cd.update(defaults['m0'])

    t0, tf = t_span
    n_steps = int((tf - t0) / dt)
    save_at = SaveAt(ts=jnp.linspace(t0, tf, n_steps + 1))

    term = ODETerm(ode_fn)
    solver = Tsit5()

    sol = diffeqsolve(
        term,
        solver,
        t0=t0,
        t1=tf,
        dt0=dt,
        y0=y0,
        args=(params, cd),
        saveat=save_at,
    )

    return sol.ts, sol.ys


