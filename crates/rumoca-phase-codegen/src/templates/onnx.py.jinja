            name = self.unique_name()
        self.initializers.append(numpy_helper.from_array(
            np.array([value], dtype=np.float32), name))
        return name

    def add_const_int(self, value, name=None):
        if name is None:
            name = self.unique_name()
        self.initializers.append(numpy_helper.from_array(
            np.array(value, dtype=np.int64), name))
        return name


