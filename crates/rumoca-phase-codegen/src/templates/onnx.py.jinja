# =========================================================================
# Forward Euler simulation via ONNX Runtime
# =========================================================================

def simulate(t_end=1.0, dt=0.001):
    """Build ONNX model, run forward Euler via onnxruntime, return CSV string."""
    try:
        import onnxruntime as ort
    except ImportError:
        raise ImportError("onnxruntime package required: pip install onnxruntime")

    model = create_onnx_model()
    sess = ort.InferenceSession(model.SerializeToString())

    defaults = get_default_values()
    names = get_variable_names()

    x = defaults['x0'].copy()
    p = defaults['p0'].copy()
    u = defaults['u0'].copy()

    n_steps = int(t_end / dt)
    lines = []
    lines.append("time," + ",".join(names['state_names']))

    for i in range(n_steps + 1):
        t = np.array([i * dt], dtype=np.float32)
        lines.append(",".join([f"{t[0]:.10g}"] + [f"{v:.10g}" for v in x]))

        if i < n_steps:
            feed = {'t': t}
{% if dae.x | length > 0 %}
            feed['x'] = x
{% endif %}
{% if dae.p | length > 0 %}
            feed['p'] = p
{% endif %}
{% if dae.u | length > 0 %}
            feed['u'] = u
{% endif %}
            result = sess.run(None, feed)
            xdot = result[0]
            x = x + dt * xdot

    return "\n".join(lines)


