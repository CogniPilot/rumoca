        name = f'_t{self._counter}'
        self._counter += 1
        return name

    def add_node(self, op, inputs, output=None, **attrs):
        if output is None:
            output = self.unique_name()
        self.nodes.append(helper.make_node(op, inputs, [output], **attrs))
        return output

    def add_const(self, value, name=None):
