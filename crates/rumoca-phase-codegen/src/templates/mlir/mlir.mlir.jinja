{#- MLIR textual IR — Generated by Rumoca from solve-IR scalar fallback rows.
    Dialects: arith, math, memref, func (standard MLIR 18, no custom ops).

    SSA naming convention: every register slot `dst` in row `R` becomes `%rR_dst`.
    `LoadTime` and `Move` emit a trivial arith.addf with a zero constant so that
    every op has a unique SSA def; the canonicalize pass folds these away.

    Compile to native shared library (MLIR 18):
      mlir-opt-18 --convert-math-to-llvm --convert-arith-to-llvm \
                  --convert-func-to-llvm --finalize-memref-to-llvm \
                  --reconcile-unrealized-casts input.mlir | \
      mlir-translate-18 --mlir-to-llvmir | \
      llc-18 -filetype=obj -relocation-model=pic -o model.o && \
      clang-18 -shared -fPIC -o model.so model.o

    ABI note: each memref<?xf64> arg expands to 5 LLVM params:
      (alloc_ptr, aligned_ptr, offset: i64, size: i64, stride: i64)
    The Rust caller passes: ptr, ptr, 0, len, 1  (alloc==aligned for Rust slices).
-#}
{%- set drv_rows = solve_blocks.continuous.derivative_rhs.scalar_programs.programs
      if solve_blocks is defined and solve_blocks.continuous is defined
         and solve_blocks.continuous.derivative_rhs is defined
         and solve_blocks.continuous.derivative_rhs.scalar_programs is defined
         and solve_blocks.continuous.derivative_rhs.scalar_programs.programs is defined else (
         solve.continuous.derivative_rhs.programs
         if solve is defined and solve.continuous is defined
            and solve.continuous.derivative_rhs is defined
            and solve.continuous.derivative_rhs.programs is defined else []) %}
{%- set impl_rows = solve_implicit_rows.programs
      if solve_implicit_rows is defined and solve_implicit_rows.programs is defined else [] %}
{%- set jac_rows = solve_jacobian_rows.programs
      if solve_jacobian_rows is defined and solve_jacobian_rows.programs is defined else [] %}
{%- set root_rows = solve.events.root_conditions.programs
      if solve is defined and solve.events is defined
         and solve.events.root_conditions is defined
         and solve.events.root_conditions.programs is defined else [] %}
{%- set name = model_name | default("model") | sanitize %}

{#- ── Macro: map UnaryOp variant to MLIR dialect op ─────────────────────────
    UnaryOp serializes as a plain string ("Neg", "Sin", …), so compare with ==. -#}
{%- macro unary_mlir(op) -%}
{%- if op == "Neg" -%}arith.negf
{%- elif op == "Abs" -%}math.absf
{%- elif op == "Sqrt" -%}math.sqrt
{%- elif op == "Floor" -%}math.floor
{%- elif op == "Ceil" -%}math.ceil
{%- elif op == "Trunc" -%}math.trunc
{%- elif op == "Sin" -%}math.sin
{%- elif op == "Cos" -%}math.cos
{%- elif op == "Tan" -%}math.tan
{%- elif op == "Asin" -%}math.asin
{%- elif op == "Acos" -%}math.acos
{%- elif op == "Atan" -%}math.atan
{%- elif op == "Sinh" -%}math.sinh
{%- elif op == "Cosh" -%}math.cosh
{%- elif op == "Tanh" -%}math.tanh
{%- elif op == "Exp" -%}math.exp
{%- elif op == "Log" -%}math.log
{%- elif op == "Log10" -%}math.log10
{%- endif -%}
{%- endmacro %}

{#- ── Macro: map BinaryOp variant to MLIR dialect op (simple two-arg ops) ───
    BinaryOp serializes as a plain string ("Add", "Mul", …), so compare with ==. -#}
{%- macro binary_mlir(op) -%}
{%- if op == "Add" -%}arith.addf
{%- elif op == "Sub" -%}arith.subf
{%- elif op == "Mul" -%}arith.mulf
{%- elif op == "Div" -%}arith.divf
{%- elif op == "Pow" -%}math.powf
{%- elif op == "Atan2" -%}math.atan2
{%- elif op == "Min" -%}arith.minimumf
{%- elif op == "Max" -%}arith.maximumf
{%- endif -%}
{%- endmacro %}

{#- ── Macro: map CompareOp variant to arith.cmpf predicate string ────────────
    CompareOp serializes as a plain string ("Lt", "Ge", …), so compare with ==. -#}
{%- macro cmp_pred(op) -%}
{%- if op == "Lt" -%}olt
{%- elif op == "Le" -%}ole
{%- elif op == "Gt" -%}ogt
{%- elif op == "Ge" -%}oge
{%- elif op == "Eq" -%}oeq
{%- elif op == "Ne" -%}one
{%- endif -%}
{%- endmacro %}

{#- ── Macro: emit MLIR SSA instructions for one LinearOp ─────────────────────
    r — row index (unique across all rows in the enclosing function)
    i — output index written by StoreOutput -#}
{%- macro emit_op(op, r, i) %}
{%- if op.Const is defined %}
    %r{{ r }}_{{ op.Const.dst }} = arith.constant {{ op.Const.value }} : f64
{%- elif op.LoadTime is defined %}
    %ltc{{ r }}_{{ op.LoadTime.dst }} = arith.constant 0.0 : f64
    %r{{ r }}_{{ op.LoadTime.dst }} = arith.addf %t, %ltc{{ r }}_{{ op.LoadTime.dst }} : f64
{%- elif op.LoadY is defined %}
    %iy{{ r }}_{{ op.LoadY.dst }} = arith.constant {{ op.LoadY.index }} : index
    %r{{ r }}_{{ op.LoadY.dst }} = memref.load %y[%iy{{ r }}_{{ op.LoadY.dst }}] : memref<?xf64>
{%- elif op.LoadP is defined %}
    %ip{{ r }}_{{ op.LoadP.dst }} = arith.constant {{ op.LoadP.index }} : index
    %r{{ r }}_{{ op.LoadP.dst }} = memref.load %p[%ip{{ r }}_{{ op.LoadP.dst }}] : memref<?xf64>
{%- elif op.LoadSeed is defined %}
    %is{{ r }}_{{ op.LoadSeed.dst }} = arith.constant {{ op.LoadSeed.index }} : index
    %r{{ r }}_{{ op.LoadSeed.dst }} = memref.load %seed[%is{{ r }}_{{ op.LoadSeed.dst }}] : memref<?xf64>
{%- elif op.Move is defined %}
    %mzc{{ r }}_{{ op.Move.dst }} = arith.constant 0.0 : f64
    %r{{ r }}_{{ op.Move.dst }} = arith.addf %r{{ r }}_{{ op.Move.src }}, %mzc{{ r }}_{{ op.Move.dst }} : f64
{%- elif op.Unary is defined %}
{%- set dst = op.Unary.dst %}
{%- set arg = op.Unary.arg %}
{%- set mop = unary_mlir(op.Unary.op) | trim %}
{%- if mop %}
    %r{{ r }}_{{ dst }} = {{ mop }} %r{{ r }}_{{ arg }} : f64
{%- elif op.Unary.op == "Not" %}
    %ntz{{ r }}_{{ dst }} = arith.constant 0.0 : f64
    %ntb{{ r }}_{{ dst }} = arith.cmpf oeq, %r{{ r }}_{{ arg }}, %ntz{{ r }}_{{ dst }} : f64
    %r{{ r }}_{{ dst }} = arith.uitofp %ntb{{ r }}_{{ dst }} : i1 to f64
{%- elif op.Unary.op == "Sign" %}
    %sgz{{ r }}_{{ dst }} = arith.constant 0.0 : f64
    %sgo{{ r }}_{{ dst }} = arith.constant 1.0 : f64
    %sgn{{ r }}_{{ dst }} = arith.constant -1.0 : f64
    %sggt{{ r }}_{{ dst }} = arith.cmpf ogt, %r{{ r }}_{{ arg }}, %sgz{{ r }}_{{ dst }} : f64
    %sglt{{ r }}_{{ dst }} = arith.cmpf olt, %r{{ r }}_{{ arg }}, %sgz{{ r }}_{{ dst }} : f64
    %sgsl{{ r }}_{{ dst }} = arith.select %sglt{{ r }}_{{ dst }}, %sgn{{ r }}_{{ dst }}, %sgz{{ r }}_{{ dst }} : f64
    %r{{ r }}_{{ dst }} = arith.select %sggt{{ r }}_{{ dst }}, %sgo{{ r }}_{{ dst }}, %sgsl{{ r }}_{{ dst }} : f64
{%- endif %}
{%- elif op.Binary is defined %}
{%- set dst = op.Binary.dst %}
{%- set lhs = op.Binary.lhs %}
{%- set rhs = op.Binary.rhs %}
{%- set mop = binary_mlir(op.Binary.op) | trim %}
{%- if mop %}
    %r{{ r }}_{{ dst }} = {{ mop }} %r{{ r }}_{{ lhs }}, %r{{ r }}_{{ rhs }} : f64
{%- elif op.Binary.op == "And" %}
    %andz{{ r }}_{{ dst }} = arith.constant 0.0 : f64
    %andlb{{ r }}_{{ dst }} = arith.cmpf one, %r{{ r }}_{{ lhs }}, %andz{{ r }}_{{ dst }} : f64
    %andrb{{ r }}_{{ dst }} = arith.cmpf one, %r{{ r }}_{{ rhs }}, %andz{{ r }}_{{ dst }} : f64
    %andab{{ r }}_{{ dst }} = arith.andi %andlb{{ r }}_{{ dst }}, %andrb{{ r }}_{{ dst }} : i1
    %r{{ r }}_{{ dst }} = arith.uitofp %andab{{ r }}_{{ dst }} : i1 to f64
{%- elif op.Binary.op == "Or" %}
    %orz{{ r }}_{{ dst }} = arith.constant 0.0 : f64
    %orlb{{ r }}_{{ dst }} = arith.cmpf one, %r{{ r }}_{{ lhs }}, %orz{{ r }}_{{ dst }} : f64
    %orrb{{ r }}_{{ dst }} = arith.cmpf one, %r{{ r }}_{{ rhs }}, %orz{{ r }}_{{ dst }} : f64
    %orob{{ r }}_{{ dst }} = arith.ori %orlb{{ r }}_{{ dst }}, %orrb{{ r }}_{{ dst }} : i1
    %r{{ r }}_{{ dst }} = arith.uitofp %orob{{ r }}_{{ dst }} : i1 to f64
{%- endif %}
{%- elif op.Compare is defined %}
{%- set dst = op.Compare.dst %}
{%- set lhs = op.Compare.lhs %}
{%- set rhs = op.Compare.rhs %}
{%- set pred = cmp_pred(op.Compare.op) | trim %}
    %cmpb{{ r }}_{{ dst }} = arith.cmpf {{ pred }}, %r{{ r }}_{{ lhs }}, %r{{ r }}_{{ rhs }} : f64
    %r{{ r }}_{{ dst }} = arith.uitofp %cmpb{{ r }}_{{ dst }} : i1 to f64
{%- elif op.Select is defined %}
{%- set dst = op.Select.dst %}
    %selz{{ r }}_{{ dst }} = arith.constant 0.0 : f64
    %selb{{ r }}_{{ dst }} = arith.cmpf one, %r{{ r }}_{{ op.Select.cond }}, %selz{{ r }}_{{ dst }} : f64
    %r{{ r }}_{{ dst }} = arith.select %selb{{ r }}_{{ dst }}, %r{{ r }}_{{ op.Select.if_true }}, %r{{ r }}_{{ op.Select.if_false }} : f64
{%- elif op.LinearSolveComponent is defined %}
{%- set lsc = op.LinearSolveComponent %}
{%- set dst = lsc.dst %}
{%- set ms  = lsc.matrix_start %}
{%- set rs  = lsc.rhs_start %}
{%- set nn  = lsc.n %}
{%- set comp = lsc.component %}
{%- set n2  = nn * nn %}
{%- set pfx = "lsc" ~ r ~ "_d" ~ dst %}
    %{{ pfx }}_A = memref.alloca() : memref<{{ n2 }}xf64>
    {%- for ai in range(n2) %}
    %{{ pfx }}_ai{{ ai }} = arith.constant {{ ai }} : index
    memref.store %r{{ r }}_{{ ms + ai }}, %{{ pfx }}_A[%{{ pfx }}_ai{{ ai }}] : memref<{{ n2 }}xf64>
    {%- endfor %}
    %{{ pfx }}_b = memref.alloca() : memref<{{ nn }}xf64>
    {%- for bi in range(nn) %}
    %{{ pfx }}_bi{{ bi }} = arith.constant {{ bi }} : index
    memref.store %r{{ r }}_{{ rs + bi }}, %{{ pfx }}_b[%{{ pfx }}_bi{{ bi }}] : memref<{{ nn }}xf64>
    {%- endfor %}
    %{{ pfx }}_Aidx = memref.extract_aligned_pointer_as_index %{{ pfx }}_A : memref<{{ n2 }}xf64> -> index
    %{{ pfx }}_Ai64 = arith.index_cast %{{ pfx }}_Aidx : index to i64
    %{{ pfx }}_bidx = memref.extract_aligned_pointer_as_index %{{ pfx }}_b : memref<{{ nn }}xf64> -> index
    %{{ pfx }}_bi64 = arith.index_cast %{{ pfx }}_bidx : index to i64
    %{{ pfx }}_n = arith.constant {{ nn }} : i64
    %{{ pfx }}_comp = arith.constant {{ comp }} : i64
    %r{{ r }}_{{ dst }} = func.call @rumoca_solve_linear_component(%{{ pfx }}_Ai64, %{{ pfx }}_bi64, %{{ pfx }}_n, %{{ pfx }}_comp) : (i64, i64, i64, i64) -> f64
{%- elif op.StoreOutput is defined %}
    %outi_{{ i }} = arith.constant {{ i }} : index
    memref.store %r{{ r }}_{{ op.StoreOutput.src }}, %out[%outi_{{ i }}] : memref<?xf64>
{%- endif %}
{%- endmacro %}

{#- ── Module ──────────────────────────────────────────────────────────────────#}
// Generated by Rumoca — solve-IR MLIR textual output
// Model: {{ name }}
// y layout: states + algebraics + outputs  |  p layout: parameters + inputs + discrete + relation memory
module @{{ name }} {

  // External runtime: Gaussian-elimination linear solve (used by LinearSolveComponent rows).
  // Pointers are passed as i64 to avoid memref-descriptor ABI complexity.
  // Linked from rumoca_runtime.o compiled by compile.rs.
  func.func private @rumoca_solve_linear_component(i64, i64, i64, i64) -> f64

  // eval_derivative — state derivatives: out[i] = xdot_i = f_i(y, p, t)
  // Emits scalar fallback rows for every tensor ComputeNode until native MLIR
  // tensor emission is enabled by the target manifest.
  func.func @eval_derivative(
      %y    : memref<?xf64>,
      %p    : memref<?xf64>,
      %t    : f64,
      %out  : memref<?xf64>) {
{%- set ns = namespace(out=0) %}
{% for row in drv_rows %}{%- set r = loop.index0 %}
{%- for op in row %}{{ emit_op(op, r, ns.out) }}{%- if op.StoreOutput is defined %}{%- set ns.out = ns.out + 1 %}{%- endif %}{% endfor %}
{% endfor %}
    func.return
  }
{% if impl_rows | length > 0 %}
  // eval_implicit_rhs — DAE residual: out[i] = g_i(y, p, t)  (g = 0 at solution)
  // Implements MLS B.1a in implicit residual form.
  func.func @eval_implicit_rhs(
      %y    : memref<?xf64>,
      %p    : memref<?xf64>,
      %t    : f64,
      %out  : memref<?xf64>) {
{%- set ns = namespace(out=0) %}
{% for row in impl_rows %}{%- set r = loop.index0 %}
{%- for op in row %}{{ emit_op(op, r, ns.out) }}{%- if op.StoreOutput is defined %}{%- set ns.out = ns.out + 1 %}{%- endif %}{% endfor %}
{% endfor %}
    func.return
  }
{% endif %}
{% if jac_rows | length > 0 %}
  // eval_jacobian_v — forward-mode JVP of eval_implicit_rhs:
  //   out[i] = sum_j (d g_i / d y_j) * seed[j]
  // Used by implicit solvers (BDF) for Jacobian-vector products.
  func.func @eval_jacobian_v(
      %y    : memref<?xf64>,
      %p    : memref<?xf64>,
      %seed : memref<?xf64>,
      %t    : f64,
      %out  : memref<?xf64>) {
{%- set ns = namespace(out=0) %}
{% for row in jac_rows %}{%- set r = loop.index0 %}
{%- for op in row %}{{ emit_op(op, r, ns.out) }}{%- if op.StoreOutput is defined %}{%- set ns.out = ns.out + 1 %}{%- endif %}{% endfor %}
{% endfor %}
    func.return
  }
{% endif %}
{% if root_rows | length > 0 %}
  // eval_root_conditions — zero-crossing indicators: out[i] = g_i(y, p, t)
  // An event fires when out[i] changes sign.
  func.func @eval_root_conditions(
      %y    : memref<?xf64>,
      %p    : memref<?xf64>,
      %t    : f64,
      %out  : memref<?xf64>) {
{%- set ns = namespace(out=0) %}
{% for row in root_rows %}{%- set r = loop.index0 %}
{%- for op in row %}{{ emit_op(op, r, ns.out) }}{%- if op.StoreOutput is defined %}{%- set ns.out = ns.out + 1 %}{%- endif %}{% endfor %}
{% endfor %}
    func.return
  }
{% endif %}
}
