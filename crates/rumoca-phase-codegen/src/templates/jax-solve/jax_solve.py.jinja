def _linsolve_component(matrix, rhs, n, component):
	"""Solve A x = b (A row-major n*n) and return x[component]."""
	A = jnp.reshape(jnp.stack(matrix), (n, n))
	b = jnp.stack(rhs)
	return jnp.linalg.solve(A, b)[component]


def rhs(x, u, p):
	"""Explicit ODE right-hand side: xdot = f(x, u, p). jit/grad/vmap-able."""
	x = jnp.asarray(x, dtype=jnp.float64)
	u = jnp.asarray(u, dtype=jnp.float64)
	p = jnp.asarray(p, dtype=jnp.float64)
	# Compiled parameter vector the bytecode indexes: [params, inputs, pad].
	_parts = [p, u] + ([jnp.zeros(_PAD)] if _PAD > 0 else [])
	P = jnp.concatenate(_parts)
