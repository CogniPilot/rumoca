{% for t_event in dae.scheduled_time_events | default([]) %}
        {{ t_event }}{{ "," if not loop.last else "" }}
{% endfor %}
    };
    static const int n_scheduled = {{ dae.scheduled_time_events | default([]) | length }};
    for (int i = 0; i < n_scheduled; i++) {
        double tol = 1.0e-12 * (1.0 + fabs(scheduled_events[i]));
        if (fabs(time - scheduled_events[i]) <= tol) return 1;
    }
{% else %}
    (void)time;
{% endif %}
    return 0;
}

static void compute_event_discrete_updates(ModelInstance* m) {
    double saved_time = m->time;
    if (m->root_event_pending || scheduled_time_event_active(m->time)) {
        m->time = event_right_limit_time(m->time);
    }
    compute_discrete_updates(m, 1);
    m->time = saved_time;
}

