    m->state = modelTerminated;
    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2Reset(fmi2Component c) {
    ModelInstance* m = (ModelInstance*)c;
    initialize_defaults(m);
    m->state = modelInstantiated;
    return fmi2OK;
}

