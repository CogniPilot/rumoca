    /* Unpack states + derivative aliases (pre_ = current value for continuous vars) */
{{ unpack_vars(dae.x, "m->x", der_prefix=true, pre_array="m->x") }}
    /* Unpack inputs */
{{ unpack_vars(dae.u, "m->u", pre_array="m->u") }}
    /* Unpack parameters */
{{ unpack_vars(dae.p, "m->p") }}
    /* Unpack constants */
{{ unpack_vars(dae.constants, "m->constants") }}
    /* Unpack discrete reals (with pre-values for pre() macro) */
{{ unpack_vars(dae.z, "m->z", pre_array="m->pre_z") }}
    /* Unpack discrete valued (with pre-values for pre() macro) */
{{ unpack_vars(dae.m, "m->m", pre_array="m->pre_m") }}
    /* Mutable local aliases for algebraic variables (evaluation order matters) */
{{ unpack_vars(dae.y, "m->y", mutable=true, pre_array="m->y") }}
    /* Mutable local aliases for output variables */
{{ unpack_vars(dae.w, "m->w", mutable=true, pre_array="m->w") }}

    /* Relax explicit algebraic dependencies that are not emitted in topological order. */
    for (int __rumoca_alg_iter = 0; __rumoca_alg_iter < 64; ++__rumoca_alg_iter) {
    double __rumoca_alg_max_delta = 0.0;
    /* Evaluate output variables first (algebraics may depend on them) */
{% set ns_out = namespace(offset=0) %}
{% for name, var in dae.w | items %}
{% if var.dims %}
{% set sz = var.dims | product %}
{% for i in range(sz) %}
    {{ symbol(symbols, source_ref(name, var.dims, i + 1)) }} = {{ output_rhs_for_var_with_solve(source_ref(name, var.dims, i + 1), dae, solve, cfg, solve_row_c_cfg) }};
    __rumoca_alg_max_delta = fmax(__rumoca_alg_max_delta, fabs({{ symbol(symbols, source_ref(name, var.dims, i + 1)) }} - m->w[{{ ns_out.offset }}]));
    m->w[{{ ns_out.offset }}] = {{ symbol(symbols, source_ref(name, var.dims, i + 1)) }};  /* {{ source_ref(name, var.dims, i + 1) }} */
{% set ns_out.offset = ns_out.offset + 1 %}
{% endfor %}
{% else %}
    {{ symbol(symbols, name) }} = {{ output_rhs_for_var_with_solve(name, dae, solve, cfg, solve_row_c_cfg) }};
    __rumoca_alg_max_delta = fmax(__rumoca_alg_max_delta, fabs({{ symbol(symbols, name) }} - m->w[{{ ns_out.offset }}]));
    m->w[{{ ns_out.offset }}] = {{ symbol(symbols, name) }};  /* {{ name }} */
{% set ns_out.offset = ns_out.offset + 1 %}
{% endif %}
{% endfor %}

    /* Evaluate algebraic variables (explicit form extracted from residual 0 = y - rhs) */
{% set ns_alg = namespace(offset=0) %}
{% for name, var in dae.y | items %}
{% if var.dims %}
{% set sz = var.dims | product %}
{% for i in range(sz) %}
    {{ symbol(symbols, source_ref(name, var.dims, i + 1)) }} = {{ output_rhs_for_var_with_solve(source_ref(name, var.dims, i + 1), dae, solve, cfg, solve_row_c_cfg) }};
    __rumoca_alg_max_delta = fmax(__rumoca_alg_max_delta, fabs({{ symbol(symbols, source_ref(name, var.dims, i + 1)) }} - m->y[{{ ns_alg.offset }}]));
    m->y[{{ ns_alg.offset }}] = {{ symbol(symbols, source_ref(name, var.dims, i + 1)) }};  /* {{ source_ref(name, var.dims, i + 1) }} */
{% set ns_alg.offset = ns_alg.offset + 1 %}
{% endfor %}
{% else %}
    {{ symbol(symbols, name) }} = {{ output_rhs_for_var_with_solve(name, dae, solve, cfg, solve_row_c_cfg) }};
    __rumoca_alg_max_delta = fmax(__rumoca_alg_max_delta, fabs({{ symbol(symbols, name) }} - m->y[{{ ns_alg.offset }}]));
    m->y[{{ ns_alg.offset }}] = {{ symbol(symbols, name) }};  /* {{ name }} */
{% set ns_alg.offset = ns_alg.offset + 1 %}
