    fmi2Component c,
    fmi2Boolean   noSetFMUStatePriorToCurrentPoint,
    fmi2Boolean*  enterEventMode,
    fmi2Boolean*  terminateSimulation)
{
    (void)noSetFMUStatePriorToCurrentPoint;
    ModelInstance* m = (ModelInstance*)c;

    *enterEventMode = 0;
    *terminateSimulation = 0;

#if N_EVENT_INDICATORS > 0
    /* Check for zero-crossings in event indicators */
    compute_event_indicators(m);
    int any_root_event = 0;
    for (int i = 0; i < N_EVENT_INDICATORS; i++) {
        if (event_indicator_crossed(m->event_indicators_prev[i], m->event_indicators[i])) {
            *enterEventMode = 1;
            m->root_event_pending = 1;
            any_root_event = 1;
        }
    }
    if (any_root_event) {
        snapshot_pre_parameters(m);
    }
{% for target in solve_root_relation_memory_targets %}
    if (event_indicator_crossed(m->event_indicators_prev[{{ loop.index0 }}], m->event_indicators[{{ loop.index0 }}])) {
        {{ render_optional_solve_slot_assign_c(target, "root_relation_memory_value(m->event_indicators_prev[" ~ loop.index0 ~ "], m->event_indicators[" ~ loop.index0 ~ "])", solve_slot_assign_c_cfg) }}
    }
{% endfor %}
    memcpy(m->event_indicators_prev, m->event_indicators, sizeof(m->event_indicators));
#else
    (void)m;
#endif

    return fmi2OK;
}

