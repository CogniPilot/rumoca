static double __rumoca_solve_y(const ModelInstance* m, int index) {
    switch (index) {
{{ solve_y_get_cases_for_vars(dae.x, "m->x") }}
{{ solve_y_get_cases_for_vars(dae.y, "m->y") }}
{{ solve_y_get_cases_for_vars(dae.w, "m->w") }}
        default: break;
    }
    if (index < N_STATES) {
        return m->x[index];
    }
    index -= N_STATES;
    if (index < N_ALGEBRAICS) {
        return m->y[index];
    }
    index -= N_ALGEBRAICS;
    if (index < N_OUTPUTS) {
        return m->w[index];
    }
    return 0.0;
}

static double __rumoca_solve_p(const ModelInstance* m, int index) {
    if (index < N_PARAMETERS) {
        return m->p[index];
    }
    index -= N_PARAMETERS;
    if (index < N_INPUTS) {
        return m->u[index];
    }
    index -= N_INPUTS;
    if (index < N_DISCRETE_REAL) {
        return m->z[index];
    }
    index -= N_DISCRETE_REAL;
    if (index < N_DISCRETE_VAL) {
        return m->m[index];
    }
    return 0.0;
}

static void __rumoca_solve_set_y(ModelInstance* m, int index, double value) {
    switch (index) {
{{ solve_y_set_cases_for_vars(dae.x, "m->x") }}
{{ solve_y_set_cases_for_vars(dae.y, "m->y") }}
{{ solve_y_set_cases_for_vars(dae.w, "m->w") }}
        default: break;
    }
    if (index < N_STATES) {
        m->x[index] = value;
        return;
    }
    index -= N_STATES;
    if (index < N_ALGEBRAICS) {
        m->y[index] = value;
        return;
    }
    index -= N_ALGEBRAICS;
    if (index < N_OUTPUTS) {
        m->w[index] = value;
        return;
    }
}

static void __rumoca_solve_set_p(ModelInstance* m, int index, double value) {
    if (index < N_PARAMETERS) {
        m->p[index] = value;
        return;
    }
    index -= N_PARAMETERS;
    if (index < N_INPUTS) {
        m->u[index] = value;
        return;
    }
    index -= N_INPUTS;
    if (index < N_DISCRETE_REAL) {
        m->z[index] = value;
        return;
    }
    index -= N_DISCRETE_REAL;
    if (index < N_DISCRETE_VAL) {
        m->m[index] = value;
        return;
    }
}

