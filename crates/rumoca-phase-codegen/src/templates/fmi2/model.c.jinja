FMI2_EXPORT fmi2Status fmi2GetReal(
    fmi2Component c,
    const fmi2ValueReference vr[], size_t nvr,
    fmi2Real value[])
{
    ModelInstance* m = (ModelInstance*)c;

    if (m->dirty_values) {
        compute_derivatives(m);
        compute_outputs(m);
        m->dirty_values = 0;
    }

    for (size_t i = 0; i < nvr; i++) {
        fmi2Status s = get_real_by_vr(m, vr[i], &value[i]);
        if (s != fmi2OK) return s;
    }
    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2SetReal(
    fmi2Component c,
    const fmi2ValueReference vr[], size_t nvr,
    const fmi2Real value[])
{
    ModelInstance* m = (ModelInstance*)c;

    for (size_t i = 0; i < nvr; i++) {
        fmi2Status s = set_real_by_vr(m, vr[i], value[i]);
        if (s != fmi2OK) return s;
    }
    m->dirty_values = 1;
    return fmi2OK;
}

