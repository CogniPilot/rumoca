FMI2_EXPORT fmi2Component fmi2Instantiate(
    fmi2String instanceName,
    fmi2Type   fmuType,
    fmi2String fmuGUID,
    fmi2String fmuResourceLocation,
    const fmi2CallbackFunctions* functions,
    fmi2Boolean visible,
    fmi2Boolean loggingOn)
{
    (void)fmuResourceLocation;
    (void)visible;
    (void)loggingOn;
    (void)functions;

    if (fmuType != fmi2ModelExchange && fmuType != fmi2CoSimulation) {
        return NULL;
    }
    if (strcmp(fmuGUID, MODEL_GUID) != 0) {
        return NULL;
    }

    ModelInstance* m = (ModelInstance*)calloc(1, sizeof(ModelInstance));
    if (!m) return NULL;
    m->instance_name = instanceName;
    m->guid = fmuGUID;
    m->fmu_type = fmuType;
    m->state = modelInstantiated;

    initialize_defaults(m);

    return (fmi2Component)m;
}

FMI2_EXPORT void fmi2FreeInstance(fmi2Component c) {
    if (c) {
        free_runtime_external_objects((ModelInstance*)c);
        free(c);
    }
}

FMI2_EXPORT fmi2Status fmi2SetupExperiment(
    fmi2Component c,
    fmi2Boolean   toleranceDefined,
    fmi2Real      tolerance,
    fmi2Real      startTime,
    fmi2Boolean   stopTimeDefined,
    fmi2Real      stopTime)
{
    (void)toleranceDefined;
    (void)tolerance;
    (void)stopTimeDefined;
    (void)stopTime;

    ModelInstance* m = (ModelInstance*)c;
    m->time = startTime;
    free_runtime_external_objects(m);
    initialize_runtime_external_objects(m);
    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2EnterInitializationMode(fmi2Component c) {
    ModelInstance* m = (ModelInstance*)c;
    m->state = modelInitializationMode;
    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2ExitInitializationMode(fmi2Component c) {
    ModelInstance* m = (ModelInstance*)c;

    compute_parameter_bindings(m);
    compute_initial_updates(m);

    /* Seed pre-values from initialized discrete state before evaluating any initial discrete updates. */
    memcpy(m->pre_z, m->z, sizeof(m->z));
    memcpy(m->pre_m, m->m, sizeof(m->m));
    snapshot_pre_parameters(m);
    compute_discrete_updates(m, 1);
    memcpy(m->pre_z, m->z, sizeof(m->z));
    memcpy(m->pre_m, m->m, sizeof(m->m));
    snapshot_pre_parameters(m);

    /* Compute initial derivatives and outputs */
    compute_derivatives(m);
    compute_outputs(m);
    m->dirty_values = 0;
    compute_event_indicators(m);
    memcpy(m->event_indicators_prev, m->event_indicators, sizeof(m->event_indicators));

    m->state = modelEventMode;
    return fmi2OK;
}

/* =========================================================================
 * FMI 2.0 API — Getters / Setters
