FMI2_EXPORT fmi2Component fmi2Instantiate(
    fmi2String instanceName,
    fmi2Type   fmuType,
    fmi2String fmuGUID,
    fmi2String fmuResourceLocation,
    const fmi2CallbackFunctions* functions,
    fmi2Boolean visible,
    fmi2Boolean loggingOn)
{
    (void)fmuResourceLocation;
    (void)visible;
    (void)loggingOn;
    (void)functions;

    if (fmuType != fmi2ModelExchange && fmuType != fmi2CoSimulation) {
        return NULL;
    }
    if (strcmp(fmuGUID, MODEL_GUID) != 0) {
        return NULL;
    }

    ModelInstance* m = (ModelInstance*)calloc(1, sizeof(ModelInstance));
    if (!m) return NULL;
    m->instance_name = instanceName;
    m->guid = fmuGUID;
    m->fmu_type = fmuType;
    m->state = modelInstantiated;

    initialize_defaults(m);

    return (fmi2Component)m;
}

