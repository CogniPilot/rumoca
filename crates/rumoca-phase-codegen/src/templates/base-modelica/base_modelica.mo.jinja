{#- BaseModelica output — flat model in the BaseModelica interchange format.
    Ref: Modelica Association BaseModelica specification (2021+).

    Differences from flat_modelica.mo.jinja:
    - Emits `model` class keyword (not `class`), matching BaseModelica §2
    - Sections are labelled with explicit comments for toolchain interop
    - State variable derivatives are declared as explicit Real variables
      (der_x) alongside the state x, per BaseModelica convention
    - Protected section uses BaseModelica's `protected` block syntax
    - Function bodies are included where available
-#}
{%- set cfg = {
  "power": "^",
  "and_op": "and",
  "or_op": "or",
  "not_op": "not ",
  "true_val": "true",
  "false_val": "false",
  "array_start": "{",
  "array_end": "}",
  "if_style": "modelica",
  "sanitize_dots": false,
  "one_based_index": true,
  "modelica_builtins": true
} %}

{#- ── Macros (shared with flat_modelica) ─────────────────────────────────────#}
{%- macro var_attrs(var) -%}
{%- set ns = namespace(parts="") -%}
{%- if var.quantity -%}{%- set ns.parts = ns.parts ~ (", " if ns.parts else "") ~ 'quantity = "' ~ var.quantity ~ '"' -%}{%- endif -%}
{%- if var.unit -%}{%- set ns.parts = ns.parts ~ (", " if ns.parts else "") ~ 'unit = "' ~ var.unit ~ '"' -%}{%- endif -%}
{%- if var.display_unit -%}{%- set ns.parts = ns.parts ~ (", " if ns.parts else "") ~ 'displayUnit = "' ~ var.display_unit ~ '"' -%}{%- endif -%}
{%- if var.min is not none -%}{%- set ns.parts = ns.parts ~ (", " if ns.parts else "") ~ "min = " ~ render_expr(var.min, cfg) -%}{%- endif -%}
{%- if var.max is not none -%}{%- set ns.parts = ns.parts ~ (", " if ns.parts else "") ~ "max = " ~ render_expr(var.max, cfg) -%}{%- endif -%}
{%- if var.start is not none -%}{%- set ns.parts = ns.parts ~ (", " if ns.parts else "") ~ "start = " ~ render_expr(var.start, cfg) -%}{%- endif -%}
{%- if var.fixed is not none -%}{%- set ns.parts = ns.parts ~ (", " if ns.parts else "") ~ "fixed = " ~ ("true" if var.fixed else "false") -%}{%- endif -%}
{%- if var.nominal is not none -%}{%- set ns.parts = ns.parts ~ (", " if ns.parts else "") ~ "nominal = " ~ render_expr(var.nominal, cfg) -%}{%- endif -%}
{%- if ns.parts %}({{ ns.parts }}){% endif -%}
{%- endmacro %}

{%- macro var_desc(var) -%}
{%- if var.description %} "{{ var.description }}"{% endif -%}
{%- endmacro %}

{%- macro dims(var) -%}
{%- if var.dims | length > 0 %}[{{ var.dims | join(", ") }}]{% endif -%}
{%- endmacro %}

{%- macro var_prefix(flat, name, var) -%}
{%- if flat.variable_final_flags[name] | default(false) %}final {% endif -%}
{%- if var.variability is mapping and var.variability.Parameter is defined %}parameter {% endif -%}
{%- if var.variability is mapping and var.variability.Constant is defined %}constant {% endif -%}
{%- if var.variability is mapping and var.variability.Discrete is defined %}discrete {% endif -%}
{%- if var.causality is mapping and var.causality.Input is defined %}input {% endif -%}
{%- if var.causality is mapping and var.causality.Output is defined %}output {% endif -%}
{%- endmacro %}

{%- macro binding(var) -%}
{%- set is_pc = var.variability is mapping and (var.variability.Parameter is defined or var.variability.Constant is defined) -%}
{%- if var.binding is not none %} = {{ render_expr(var.binding, cfg) }}{% elif is_pc and var.start is not none and (var.fixed is none or var.fixed) %} = {{ render_expr(var.start, cfg) }}{% endif -%}
{%- endmacro %}

{%- macro var_type(flat, name) -%}
{{ flat.variable_type_names[name] | default("Real") }}
{%- endmacro %}

{%- macro render_assert_eq(a) -%}
assert({{ render_expr(a.condition, cfg) }}, {{ render_expr(a.message, cfg) }}{% if a.level is not none %}, {{ render_expr(a.level, cfg) }}{% endif %})
{%- endmacro %}

{#- ── Determine class keyword from flat model class_type ─────────────────────#}
{%- set class_kw = flat.class_type if flat.class_type is string and flat.class_type | lower != "none" and flat.class_type | lower != "" else "model" %}
{%- set class_kw = class_kw | lower %}
{%- if class_kw not in ["model", "block", "record", "connector", "function"] %}
{%- set class_kw = "model" %}
{%- endif %}
// BaseModelica — {{ model_name }}{% if flat.model_description %} "{{ flat.model_description }}"{% endif %}

{{ class_kw }} {{ model_name }}{% if flat.model_description %} "{{ flat.model_description }}"{% endif %}

  // --- variable declarations ---
{%- for name, var in flat.variables | items %}
{%- if not var.is_protected %}
  {{ var_prefix(flat, name, var) }}{{ var_type(flat, name) | trim }}{{ dims(var) }} {{ name }}{{ var_attrs(var) }}{{ binding(var) }}{{ var_desc(var) }};
{%- endif %}
{%- endfor %}
{%- set ns = namespace(has_protected=false) %}
{%- for _n, var in flat.variables | items %}
{%- if var.is_protected %}{%- set ns.has_protected = true %}{%- endif %}
{%- endfor %}
{%- if ns.has_protected %}

protected
  // --- protected declarations ---
{%- for name, var in flat.variables | items %}
{%- if var.is_protected %}
  {{ var_prefix(flat, name, var) }}{{ var_type(flat, name) | trim }}{{ dims(var) }} {{ name }}{{ var_attrs(var) }}{{ binding(var) }}{{ var_desc(var) }};
{%- endif %}
{%- endfor %}
{%- endif %}

equation
  // --- continuous equations ---
{%- for eq in flat.equations %}
  {{ render_flat_equation(eq, cfg) }};
{%- endfor %}
{%- for a in flat.assert_equations %}
  {{ render_assert_eq(a) }};
{%- endfor %}
{%- if flat.initial_equations | length > 0 or flat.initial_assert_equations | length > 0 %}

initial equation
  // --- initial equations ---
{%- for eq in flat.initial_equations %}
  {{ render_flat_equation(eq, cfg) }};
{%- endfor %}
{%- for a in flat.initial_assert_equations %}
  {{ render_assert_eq(a) }};
{%- endfor %}
{%- endif %}

end {{ model_name }};
