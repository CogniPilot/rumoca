#!/bin/sh
# Build script for {{ model_name }} FMI 3.0 FMU
set -e
cd "$(dirname "$0")"

ALLOW_UNRESOLVED_FLAGS=""
case "$(uname -s)" in
  Linux*)
    case "$(uname -m)" in
      x86_64|amd64)   PLATFORM=x86_64-linux ;;
      arm64|aarch64)  PLATFORM=aarch64-linux ;;
      *) echo "Unsupported Linux architecture: $(uname -m)"; exit 1 ;;
    esac
    LIB_EXT=so
    ;;
  Darwin*)
    case "$(uname -m)" in
      arm64|aarch64) PLATFORM=aarch64-darwin ;;
      *)             PLATFORM=x86_64-darwin ;;
    esac
    LIB_EXT=dylib
    ALLOW_UNRESOLVED_FLAGS="-Wl,-undefined,dynamic_lookup"
    ;;
  MINGW*|MSYS*|CYGWIN*)
    case "$(uname -m)" in
      arm64|aarch64) PLATFORM=aarch64-windows ;;
      *)             PLATFORM=x86_64-windows ;;
    esac
    LIB_EXT=dll
    ;;
  *) echo "Unknown platform"; exit 1 ;;
esac

mkdir -p binaries/$PLATFORM
: "${CFLAGS:=-O2}"
cc -shared -fPIC $CFLAGS -o binaries/$PLATFORM/{{ model_name }}.$LIB_EXT sources/{{ model_name }}.c -lm

rm -f {{ model_name }}.fmu
zip -r {{ model_name }}.fmu modelDescription.xml binaries/ sources/
echo "Created {{ model_name }}.fmu"
