cmake_minimum_required(VERSION 3.10)
project({{ model_name }} C)

set(CMAKE_C_STANDARD 99)
set(CMAKE_POSITION_INDEPENDENT_CODE ON)

add_library({{ model_name }} SHARED {{ model_name }}.c)
if(MSVC)
  target_compile_options({{ model_name }} PRIVATE /W4)
else()
  target_compile_options({{ model_name }} PRIVATE -Wall -Wextra -pedantic)
endif()

string(TOLOWER "${CMAKE_SYSTEM_PROCESSOR}" FMU_PROCESSOR)
if(FMU_PROCESSOR MATCHES "^(arm64|aarch64)$")
  set(FMU_ARCH "aarch64")
elseif(FMU_PROCESSOR MATCHES "^(amd64|x86_64)$")
  set(FMU_ARCH "x86_64")
else()
  message(FATAL_ERROR "Unsupported architecture for FMI 3.0 FMU packaging: ${CMAKE_SYSTEM_PROCESSOR}")
endif()

if(WIN32)
  set(FMU_PLATFORM "${FMU_ARCH}-windows")
elseif(APPLE)
  set(FMU_PLATFORM "${FMU_ARCH}-darwin")
elseif(UNIX)
  set(FMU_PLATFORM "${FMU_ARCH}-linux")
else()
  message(FATAL_ERROR "Unsupported platform for FMI 3.0 FMU packaging")
endif()

install(TARGETS {{ model_name }}
    RUNTIME DESTINATION binaries/${FMU_PLATFORM}
    LIBRARY DESTINATION binaries/${FMU_PLATFORM})
