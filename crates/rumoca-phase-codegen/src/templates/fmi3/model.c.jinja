FMI3_Export fmi3Status fmi3GetContinuousStates(
    fmi3Instance instance,
    fmi3Float64 continuousStates[], size_t nContinuousStates)
{
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || m->is_co_simulation || nContinuousStates != N_STATES ||
