static double __rumoca_solve_linear_component(const double* A_in, const double* b_in, int n, int component) {
    if (n <= 0 || n > RUMOCA_MAX_LINEAR_SOLVE || component < 0 || component >= n) {
        return NAN;
    }

    double A[RUMOCA_MAX_LINEAR_SOLVE][RUMOCA_MAX_LINEAR_SOLVE] = {0};
    double b[RUMOCA_MAX_LINEAR_SOLVE] = {0};
    for (int row = 0; row < n; row++) {
        b[row] = b_in[row];
        for (int col = 0; col < n; col++) {
            A[row][col] = A_in[row * n + col];
        }
    }

    for (int col = 0; col < n; col++) {
        int pivot = col;
        double pivot_abs = fabs(A[col][col]);
        for (int row = col + 1; row < n; row++) {
            double candidate = fabs(A[row][col]);
            if (candidate > pivot_abs) {
                pivot = row;
                pivot_abs = candidate;
            }
        }
        if (pivot_abs < 1.0e-12) {
            return NAN;
        }
        if (pivot != col) {
            for (int j = col; j < n; j++) {
                double tmp = A[col][j];
                A[col][j] = A[pivot][j];
                A[pivot][j] = tmp;
            }
            double tmp_b = b[col];
            b[col] = b[pivot];
            b[pivot] = tmp_b;
        }

        double inv_pivot = 1.0 / A[col][col];
        for (int row = col + 1; row < n; row++) {
            double factor = A[row][col] * inv_pivot;
            A[row][col] = 0.0;
            for (int j = col + 1; j < n; j++) {
                A[row][j] -= factor * A[col][j];
            }
            b[row] -= factor * b[col];
        }
    }

    double x[RUMOCA_MAX_LINEAR_SOLVE] = {0};
    for (int row = n - 1; row >= 0; row--) {
        double sum = b[row];
        for (int col = row + 1; col < n; col++) {
            sum -= A[row][col] * x[col];
        }
        x[row] = sum / A[row][row];
    }
    return x[component];
}

