{% if rhs %}
    m->x[{{ ns_init.offset }}] = {{ rhs }};  /* initial equation: {{ name }} */
{% set ns_init.emitted = true %}
{% endif %}
{% set ns_init.offset = ns_init.offset + 1 %}
{% endif %}
{% endfor %}
{% if not ns_init.emitted %}
    (void)m;
{% endif %}
}

