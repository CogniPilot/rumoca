}

FMI3_Export fmi3Status fmi3GetContinuousStateDerivatives(
    fmi3Instance instance,
    fmi3Float64 derivatives[], size_t nContinuousStates)
{
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || m->is_co_simulation || nContinuousStates != N_DERIVATIVES ||
        (nContinuousStates > 0 && !derivatives)) return fmi3Error;

    if (m->dirty_values) {
        compute_derivatives(m);
    }
    if (m->evaluation_error) return fmi3Error;

    memcpy(derivatives, m->xdot, nContinuousStates * sizeof(fmi3Float64));
    return fmi3OK;
}

FMI3_Export fmi3Status fmi3GetEventIndicators(
    fmi3Instance instance,
    fmi3Float64 eventIndicators[], size_t nEventIndicators)
{
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || m->is_co_simulation || nEventIndicators != N_EVENT_INDICATORS ||
        (nEventIndicators > 0 && !eventIndicators)) return fmi3Error;

    if (m->dirty_values) compute_derivatives(m);
    if (m->evaluation_error) return fmi3Error;
    compute_event_indicators(m);
    for (size_t i = 0; i < nEventIndicators; i++) {
        eventIndicators[i] = exposed_event_indicator(m, (int)i, m->event_indicators[i]);
    }
    return fmi3OK;
}

