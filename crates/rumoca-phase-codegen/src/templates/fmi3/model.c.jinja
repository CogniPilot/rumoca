static int periodic_next_time(double time, double phase, double period, double* candidate) {
    const double first_representable_time = nextafter(time, INFINITY);
    double cycle = ceil((first_representable_time - phase) / period);
    if (!isfinite(cycle)) return 0;
    if (cycle < 0.0) cycle = 0.0;

    *candidate = fma(cycle, period, phase);
    while (isfinite(*candidate) && *candidate <= time) {
        double next_cycle = cycle + 1.0;
        if (next_cycle <= cycle) next_cycle = nextafter(cycle, INFINITY);
        if (!isfinite(next_cycle) || next_cycle <= cycle) return 0;
        cycle = next_cycle;
        *candidate = fma(cycle, period, phase);
    }
    return isfinite(*candidate);
}

static int next_time_event(ModelInstance* m, double* next_time) {
    const double time = m->time;
    int defined = 0;
{% for root in solve_scheduled_root_conditions %}
    {
        const double period = {{ root.period_seconds }};
        const double phase = {{ root.phase_seconds }};
        double candidate = 0.0;
        if (periodic_next_time(time, phase, period, &candidate) &&
            (!defined || candidate < *next_time)) {
            *next_time = candidate;
            defined = 1;
        }
    }
{% endfor %}
{% for t_event in dae.scheduled_time_events | default([]) %}
    if ({{ t_event }} > time && (!defined || {{ t_event }} < *next_time)) {
        *next_time = {{ t_event }};
        defined = 1;
    }
{% endfor %}
{% if solve_dynamic_time_rows | length > 0 %}
    double dynamic_events[{{ solve_dynamic_time_rows | length }}];
    {{ render_solve_block_c(solve_dynamic_time_rows, solve_row_c_cfg, "dynamic_events[{}] = {}") }}
    for (int i = 0; i < {{ solve_dynamic_time_rows | length }}; i++) {
        const double candidate = dynamic_events[i];
        if (isfinite(candidate) && candidate > time &&
            (!defined || candidate < *next_time)) {
            *next_time = candidate;
            defined = 1;
        }
    }
{% endif %}
    return defined;
}

