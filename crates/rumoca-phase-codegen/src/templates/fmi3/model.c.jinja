        return m->x[index];
    }
    index -= N_STATES;
    if (index < N_ALGEBRAICS) {
        return m->y[index];
    }
    index -= N_ALGEBRAICS;
    if (index < N_OUTPUTS) {
        return m->w[index];
    }
    return 0.0;
}

static double __rumoca_solve_p(const ModelInstance* m, int index) {
