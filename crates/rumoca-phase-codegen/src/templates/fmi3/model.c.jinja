    }
    index -= N_INPUTS;
    if (index < N_DISCRETE_REAL) {
        return m->z[index];
    }
    index -= N_DISCRETE_REAL;
    if (index < N_DISCRETE_VAL) {
        return m->m[index];
    }
    return 0.0;
}

static void __rumoca_solve_set_y(ModelInstance* m, int index, double value) {
    if (index < N_STATES) {
        m->x[index] = value;
        return;
    }
    index -= N_STATES;
    if (index < N_ALGEBRAICS) {
        m->y[index] = value;
        return;
    }
    index -= N_ALGEBRAICS;
    if (index < N_OUTPUTS) {
        m->w[index] = value;
        return;
    }
}

static void __rumoca_solve_set_p(ModelInstance* m, int index, double value) {
    if (index < N_PARAMETERS) {
        m->p[index] = value;
        return;
    }
    index -= N_PARAMETERS;
    if (index < N_INPUTS) {
        m->u[index] = value;
        return;
    }
    index -= N_INPUTS;
    if (index < N_DISCRETE_REAL) {
        m->z[index] = value;
        return;
    }
    index -= N_DISCRETE_REAL;
    if (index < N_DISCRETE_VAL) {
        m->m[index] = value;
        return;
    }
}

