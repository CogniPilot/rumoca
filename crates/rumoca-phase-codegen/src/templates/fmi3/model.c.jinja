/* =========================================================================
 * FMI 3.0 API — Partial Derivatives
 * ========================================================================= */

FMI3_Export fmi3Status fmi3GetDirectionalDerivative(
    fmi3Instance instance,
    const fmi3ValueReference unknowns[], size_t nUnknowns,
    const fmi3ValueReference knowns[], size_t nKnowns,
    const fmi3Float64 seed[], size_t nSeed,
    fmi3Float64 sensitivity[], size_t nSensitivity)
{
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || (nUnknowns > 0 && !unknowns) || (nKnowns > 0 && !knowns) ||
        (nSeed > 0 && !seed) || (nSensitivity > 0 && !sensitivity)) return fmi3Error;
    for (size_t si = 0; si < nSensitivity; si++) sensitivity[si] = 0.0;

    if (N_SOLVE_JACOBIAN_ROWS == 0) return fmi3Error;

    fmi3Float64 solve_seed[N_SOLVE_SEEDS > 0 ? N_SOLVE_SEEDS : 1] = {0};
    fmi3Float64 jv[N_SOLVE_JACOBIAN_ROWS > 0 ? N_SOLVE_JACOBIAN_ROWS : 1] = {0};

    size_t seed_idx = 0;
    for (size_t j = 0; j < nKnowns; j++) {
        int k_count = vr_scalar_count(knowns[j]);
        for (int ke = 0; ke < k_count; ke++) {
            int seed_offset = solve_seed_offset_for_vr_element(knowns[j], ke);
            if (seed_offset < 0 || seed_offset >= N_SOLVE_SEEDS) return fmi3Error;
            if (seed_idx + (size_t)ke >= nSeed) return fmi3Error;
            solve_seed[seed_offset] += seed[seed_idx + ke];
        }
        seed_idx += k_count;
    }
    if (seed_idx != nSeed) return fmi3Error;

    compute_solve_jacobian_v(m, solve_seed, jv);

    size_t sens_idx = 0;
    for (size_t i = 0; i < nUnknowns; i++) {
        int u_count = vr_scalar_count(unknowns[i]);
        int u_offset = xdot_flat_offset_for_vr(unknowns[i]);
        if (u_offset < 0 || u_offset + u_count > N_SOLVE_JACOBIAN_ROWS) return fmi3Error;
        for (int ue = 0; ue < u_count; ue++) {
            if (sens_idx + (size_t)ue >= nSensitivity) return fmi3Error;
            sensitivity[sens_idx + ue] = jv[u_offset + ue];
        }
        sens_idx += u_count;
    }
    if (sens_idx != nSensitivity) return fmi3Error;

    return fmi3OK;
}

FMI3_Export fmi3Status fmi3GetAdjointDerivative(
    fmi3Instance instance,
    const fmi3ValueReference unknowns[], size_t nUnknowns,
    const fmi3ValueReference knowns[], size_t nKnowns,
    const fmi3Float64 seed[], size_t nSeed,
    fmi3Float64 sensitivity[], size_t nSensitivity)
{
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || (nUnknowns > 0 && !unknowns) || (nKnowns > 0 && !knowns) ||
        (nSeed > 0 && !seed) || (nSensitivity > 0 && !sensitivity)) return fmi3Error;
    for (size_t si = 0; si < nSensitivity; si++) sensitivity[si] = 0.0;

    if (N_SOLVE_JACOBIAN_ROWS == 0) return fmi3Error;

    fmi3Float64 solve_seed[N_SOLVE_SEEDS > 0 ? N_SOLVE_SEEDS : 1] = {0};
    fmi3Float64 jv[N_SOLVE_JACOBIAN_ROWS > 0 ? N_SOLVE_JACOBIAN_ROWS : 1] = {0};
    size_t sens_idx = 0;
    for (size_t j = 0; j < nKnowns; j++) {
        int k_count = vr_scalar_count(knowns[j]);
        for (int ke = 0; ke < k_count; ke++) {
            if (sens_idx + (size_t)ke >= nSensitivity) return fmi3Error;
            int seed_offset = solve_seed_offset_for_vr_element(knowns[j], ke);
            if (seed_offset < 0 || seed_offset >= N_SOLVE_SEEDS) return fmi3Error;
            memset(solve_seed, 0, sizeof(solve_seed));
            solve_seed[seed_offset] = 1.0;
            compute_solve_jacobian_v(m, solve_seed, jv);

            size_t seed_idx = 0;
            for (size_t i = 0; i < nUnknowns; i++) {
                int u_count = vr_scalar_count(unknowns[i]);
                int u_offset = xdot_flat_offset_for_vr(unknowns[i]);
                if (u_offset < 0 || u_offset + u_count > N_SOLVE_JACOBIAN_ROWS) return fmi3Error;
                for (int ue = 0; ue < u_count; ue++) {
                    if (seed_idx + (size_t)ue >= nSeed) return fmi3Error;
                    sensitivity[sens_idx + ke] += seed[seed_idx + ue] * jv[u_offset + ue];
                }
                seed_idx += u_count;
            }
            if (seed_idx != nSeed) return fmi3Error;
        }
        sens_idx += k_count;
    }
    if (sens_idx != nSensitivity) return fmi3Error;

    return fmi3OK;
}

/* =========================================================================
 * FMI 3.0 API — Co-Simulation (§4.2)
 *
 * Adaptive Dormand-Prince stepping is the portable default. Deterministic
 * lockstep users can define RUMOCA_FMI3_COSIM_FIXED_RK4 and optionally
 * RUMOCA_FMI3_COSIM_RK4_MAX_STEP when building the FMU. For production-grade
 * solver control, prefer Model Exchange with an external solver.
 * ========================================================================= */

static fmi3Status rk45_eval(ModelInstance* m, double t, const fmi3Float64 x[], fmi3Float64 dxdt[]);

#define RUMOCA_EVENT_BISECTION_ITERS 32
#define RUMOCA_EVENT_ITERATION_LIMIT 16

static int any_event_indicator_crossed(
    const fmi3Float64 before[], const fmi3Float64 after[])
{
#if N_EVENT_INDICATORS > 0
    for (int i = 0; i < N_EVENT_INDICATORS; i++) {
        if (event_indicator_crossed(before[i], after[i])) return 1;
    }
#else
    (void)before; (void)after;
#endif
    return 0;
}

static fmi3Status rk4_trial_state(
    ModelInstance* m, double t, const fmi3Float64 x[], double h, fmi3Float64 result[])
{
#if N_STATES > 0
    fmi3Float64 stage[N_STATES];
    fmi3Float64 k1[N_STATES];
    fmi3Float64 k2[N_STATES];
    fmi3Float64 k3[N_STATES];
    fmi3Float64 k4[N_STATES];

    if (rk45_eval(m, t, x, k1) != fmi3OK) return fmi3Error;
    for (int i = 0; i < N_STATES; i++) stage[i] = x[i] + 0.5 * h * k1[i];
    if (rk45_eval(m, t + 0.5 * h, stage, k2) != fmi3OK) return fmi3Error;
    for (int i = 0; i < N_STATES; i++) stage[i] = x[i] + 0.5 * h * k2[i];
    if (rk45_eval(m, t + 0.5 * h, stage, k3) != fmi3OK) return fmi3Error;
    for (int i = 0; i < N_STATES; i++) stage[i] = x[i] + h * k3[i];
    if (rk45_eval(m, t + h, stage, k4) != fmi3OK) return fmi3Error;
    for (int i = 0; i < N_STATES; i++) {
        result[i] = x[i] + h * (k1[i] + 2.0 * k2[i] + 2.0 * k3[i] + k4[i]) / 6.0;
    }
    return fmi3OK;
#else
    (void)m; (void)t; (void)x; (void)h; (void)result;
    return fmi3OK;
#endif
}

static fmi3Status evaluate_event_indicators_at(
    ModelInstance* m, double t, const fmi3Float64 x[], fmi3Float64 indicators[])
{
#if N_STATES > 0
    memcpy(m->x, x, N_STATES * sizeof(fmi3Float64));
#else
    (void)x;
#endif
    m->time = t;
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) return fmi3Error;
    compute_event_indicators(m);
#if N_EVENT_INDICATORS > 0
    memcpy(indicators, m->event_indicators, sizeof(m->event_indicators));
#else
    (void)indicators;
#endif
    return fmi3OK;
}

static fmi3Status locate_internal_root(
    ModelInstance* m,
    double t_start,
    const fmi3Float64 x_start[],
    const fmi3Float64 roots_start[],
    double t_stop,
    const fmi3Float64 x_stop[],
    double* root_time,
    fmi3Float64 root_state[],
    fmi3Float64 roots_after[])
{
#if N_STATES > 0 && N_EVENT_INDICATORS > 0
    double low = t_start;
    double high = t_stop;
    fmi3Float64 high_state[N_STATES];
    fmi3Float64 midpoint_state[N_STATES];
    fmi3Float64 midpoint_roots[N_EVENT_INDICATORS];
    memcpy(high_state, x_stop, sizeof(high_state));

    for (int iteration = 0; iteration < RUMOCA_EVENT_BISECTION_ITERS; iteration++) {
        const double midpoint = low + 0.5 * (high - low);
        if (rk4_trial_state(m, t_start, x_start, midpoint - t_start, midpoint_state) != fmi3OK ||
            evaluate_event_indicators_at(m, midpoint, midpoint_state, midpoint_roots) != fmi3OK) {
            return fmi3Error;
        }
        if (any_event_indicator_crossed(roots_start, midpoint_roots)) {
            high = midpoint;
            memcpy(high_state, midpoint_state, sizeof(high_state));
        } else {
            low = midpoint;
        }
    }

    *root_time = high;
    memcpy(root_state, high_state, sizeof(high_state));
    return evaluate_event_indicators_at(m, high, high_state, roots_after);
#else
    (void)m; (void)t_start; (void)x_start; (void)roots_start;
    (void)t_stop; (void)x_stop; (void)root_time; (void)root_state; (void)roots_after;
    return fmi3Error;
#endif
}

static void apply_internal_root_relation_memory(
    ModelInstance* m, const fmi3Float64 before[], const fmi3Float64 after[])
{
{% for target in solve_root_relation_memory_targets %}
    if (event_indicator_crossed(before[{{ loop.index0 }}], after[{{ loop.index0 }}])) {
        m->event_indicator_nonpositive[{{ loop.index0 }}] = root_relation_memory_value(
            {{ loop.index0 }}, before[{{ loop.index0 }}], after[{{ loop.index0 }}]);
        {{ render_optional_solve_slot_assign_c(target, "m->event_indicator_nonpositive[" ~ loop.index0 ~ "] ? 1.0 : 0.0", solve_slot_assign_c_cfg) }}
    }
{% endfor %}
{% if solve_root_relation_memory_targets | length == 0 %}
    (void)m; (void)before; (void)after;
{% endif %}
}

static fmi3Status iterate_event_discrete_update(ModelInstance* m) {
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) {
        return fmi3Error;
    }
    compute_event_indicators(m);
    refresh_root_relation_memory(m);

    fmi3Float64 old_z[N_DISCRETE_REAL > 0 ? N_DISCRETE_REAL : 1];
    fmi3Float64 old_m[N_DISCRETE_VAL > 0 ? N_DISCRETE_VAL : 1];
    fmi3Float64 old_x[N_STATES > 0 ? N_STATES : 1];
    fmi3Boolean old_domains[N_EVENT_INDICATORS > 0 ? N_EVENT_INDICATORS : 1];
    for (int iteration = 0; iteration < RUMOCA_EVENT_ITERATION_LIMIT; iteration++) {
        memcpy(old_z, m->z, sizeof(m->z));
        memcpy(old_m, m->m, sizeof(m->m));
        memcpy(old_x, m->x, sizeof(m->x));
        memcpy(old_domains, m->event_indicator_nonpositive,
               sizeof(m->event_indicator_nonpositive));
        compute_discrete_updates(m);

        m->dirty_values = 1;
        compute_derivatives(m);
        if (m->evaluation_error) return fmi3Error;
        compute_event_indicators(m);
        refresh_event_indicator_domains(m);

        if (real_values_equal(old_z, m->z, N_DISCRETE_REAL) &&
            real_values_equal(old_m, m->m, N_DISCRETE_VAL) &&
            real_values_equal(old_x, m->x, N_STATES) &&
            memcmp(old_domains, m->event_indicator_nonpositive,
                   N_EVENT_INDICATORS * sizeof(fmi3Boolean)) == 0) {
            return fmi3OK;
        }
    }
    return fmi3Error;
}

static fmi3Status process_internal_root(
    ModelInstance* m,
    double t_start,
    const fmi3Float64 x_start[],
    const fmi3Float64 roots_start[],
    double t_stop,
    const fmi3Float64 x_stop[])
{
#if N_STATES > 0 && N_EVENT_INDICATORS > 0
    double root_time = t_stop;
    fmi3Float64 root_state[N_STATES];
    fmi3Float64 roots_after[N_EVENT_INDICATORS];
    if (locate_internal_root(
            m, t_start, x_start, roots_start, t_stop, x_stop,
            &root_time, root_state, roots_after) != fmi3OK) {
        return fmi3Error;
    }

    memcpy(m->x, root_state, sizeof(root_state));
    m->time = root_time;
    memcpy(m->pre_z, m->z, sizeof(m->z));
    memcpy(m->pre_m, m->m, sizeof(m->m));
    snapshot_pre_parameters(m);
    apply_internal_root_relation_memory(m, roots_start, roots_after);
    if (iterate_event_discrete_update(m) != fmi3OK) return fmi3Error;

    m->time = root_time;
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) return fmi3Error;
    compute_event_indicators(m);
    snapshot_event_indicator_domains(m);
    return fmi3OK;
#else
    (void)m; (void)t_start; (void)x_start; (void)roots_start; (void)t_stop; (void)x_stop;
    return fmi3Error;
#endif
}

static fmi3Status restore_integration_point(ModelInstance* m, const fmi3Float64 x[], double t) {
#if N_STATES > 0
    memcpy(m->x, x, N_STATES * sizeof(fmi3Float64));
#else
    (void)x;
#endif
    m->time = t;
    m->dirty_values = 1;
    return fmi3Error;
}

#ifndef RUMOCA_FMI3_COSIM_RK4_MAX_STEP
#define RUMOCA_FMI3_COSIM_RK4_MAX_STEP INFINITY
#endif

static fmi3Status rk4_integrate(ModelInstance* m, double t_start, double t_stop) {
#if N_STATES > 0
    if (t_stop < t_start) return fmi3Error;
    if (t_stop == t_start) return fmi3OK;
    if (!(RUMOCA_FMI3_COSIM_RK4_MAX_STEP > 0.0)) return fmi3Error;

    fmi3Float64 x0[N_STATES];
    fmi3Float64 x_next[N_STATES];
    fmi3Float64 roots_before[N_EVENT_INDICATORS > 0 ? N_EVENT_INDICATORS : 1];
    fmi3Float64 roots_after[N_EVENT_INDICATORS > 0 ? N_EVENT_INDICATORS : 1];
    double t = t_start;
    double last_step_start = t_start;
    while (t < t_stop) {
        const double h = fmin(RUMOCA_FMI3_COSIM_RK4_MAX_STEP, t_stop - t);
        const double t_next = t + h;
        last_step_start = t;
        memcpy(x0, m->x, N_STATES * sizeof(fmi3Float64));
#if N_EVENT_INDICATORS > 0
        memcpy(roots_before, m->event_indicators_prev, sizeof(m->event_indicators_prev));
#endif
        if (rk4_trial_state(m, t, x0, h, x_next) != fmi3OK ||
            evaluate_event_indicators_at(m, t_next, x_next, roots_after) != fmi3OK) {
            return restore_integration_point(m, x0, t);
        }

#if N_EVENT_INDICATORS > 0
        if (any_event_indicator_crossed(roots_before, roots_after)) {
            if (process_internal_root(m, t, x0, roots_before, t_next, x_next) != fmi3OK) {
                return restore_integration_point(m, x0, t);
            }
            t = m->time;
            continue;
        }
        memcpy(m->event_indicators_prev, roots_after, sizeof(m->event_indicators_prev));
#endif
        memcpy(m->x, x_next, sizeof(x_next));
        t = t_next;
    }
    m->time = t_stop;
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) return restore_integration_point(m, x0, last_step_start);
    return fmi3OK;
#else
    (void)t_start;
    m->time = t_stop;
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) return fmi3Error;
    return fmi3OK;
#endif
}

#define RK45_ABS_TOL 1.0e-7
#define RK45_MIN_STEP 1.0e-9
#define RK45_MAX_STEP 2.0e-2

static fmi3Status rk45_eval(ModelInstance* m, double t, const fmi3Float64 x[], fmi3Float64 dxdt[]) {
#if N_STATES > 0
    memcpy(m->x, x, N_STATES * sizeof(fmi3Float64));
    m->time = t;
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) return fmi3Error;
    memcpy(dxdt, m->xdot, N_STATES * sizeof(fmi3Float64));
    for (int i = 0; i < N_STATES; i++) {
        if (!isfinite(dxdt[i])) return fmi3Error;
    }
    return fmi3OK;
#else
    (void)m; (void)t; (void)x; (void)dxdt;
    return fmi3OK;
#endif
}

static fmi3Status rk45_integrate(ModelInstance* m, double t_start, double t_stop) {
#if N_STATES > 0
    fmi3Float64 x0[N_STATES];
    fmi3Float64 x_stage[N_STATES];
    fmi3Float64 x4[N_STATES];
    fmi3Float64 x5[N_STATES];
    fmi3Float64 k1[N_STATES];
    fmi3Float64 k2[N_STATES];
    fmi3Float64 k3[N_STATES];
    fmi3Float64 k4[N_STATES];
    fmi3Float64 k5[N_STATES];
    fmi3Float64 k6[N_STATES];
    fmi3Float64 k7[N_STATES];
    fmi3Float64 roots_before[N_EVENT_INDICATORS > 0 ? N_EVENT_INDICATORS : 1];
    fmi3Float64 roots_after[N_EVENT_INDICATORS > 0 ? N_EVENT_INDICATORS : 1];

    memcpy(x0, m->x, N_STATES * sizeof(fmi3Float64));

    double t = t_start;
    if (t_stop == t_start) {
        return fmi3OK;
    }
    if (t_stop < t_start) {
        return fmi3Error;
    }

    double h = t_stop - t_start;
    if (h > RK45_MAX_STEP) {
        h = RK45_MAX_STEP;
    }

    while (t < t_stop - 1.0e-15) {
        if (h > t_stop - t) {
            h = t_stop - t;
        }
        if (h < RK45_MIN_STEP) {
            h = t_stop - t;
        }

        if (rk45_eval(m, t, x0, k1) != fmi3OK) return restore_integration_point(m, x0, t);

        for (int i = 0; i < N_STATES; i++) {
            x_stage[i] = x0[i] + h * (1.0 / 5.0) * k1[i];
        }
        if (rk45_eval(m, t + h * (1.0 / 5.0), x_stage, k2) != fmi3OK) return restore_integration_point(m, x0, t);

        for (int i = 0; i < N_STATES; i++) {
            x_stage[i] = x0[i] + h * ((3.0 / 40.0) * k1[i] + (9.0 / 40.0) * k2[i]);
        }
        if (rk45_eval(m, t + h * (3.0 / 10.0), x_stage, k3) != fmi3OK) return restore_integration_point(m, x0, t);

        for (int i = 0; i < N_STATES; i++) {
            x_stage[i] = x0[i] + h * ((44.0 / 45.0) * k1[i]
                                      - (56.0 / 15.0) * k2[i]
                                      + (32.0 / 9.0) * k3[i]);
        }
        if (rk45_eval(m, t + h * (4.0 / 5.0), x_stage, k4) != fmi3OK) return restore_integration_point(m, x0, t);

        for (int i = 0; i < N_STATES; i++) {
            x_stage[i] = x0[i] + h * ((19372.0 / 6561.0) * k1[i]
                                      - (25360.0 / 2187.0) * k2[i]
                                      + (64448.0 / 6561.0) * k3[i]
                                      - (212.0 / 729.0) * k4[i]);
        }
        if (rk45_eval(m, t + h * (8.0 / 9.0), x_stage, k5) != fmi3OK) return restore_integration_point(m, x0, t);

        for (int i = 0; i < N_STATES; i++) {
            x_stage[i] = x0[i] + h * ((9017.0 / 3168.0) * k1[i]
                                      - (355.0 / 33.0) * k2[i]
                                      + (46732.0 / 5247.0) * k3[i]
                                      + (49.0 / 176.0) * k4[i]
                                      - (5103.0 / 18656.0) * k5[i]);
        }
        if (rk45_eval(m, t + h, x_stage, k6) != fmi3OK) return restore_integration_point(m, x0, t);

        for (int i = 0; i < N_STATES; i++) {
            x5[i] = x0[i] + h * ((35.0 / 384.0) * k1[i]
                                 + (500.0 / 1113.0) * k3[i]
                                 + (125.0 / 192.0) * k4[i]
                                 - (2187.0 / 6784.0) * k5[i]
                                 + (11.0 / 84.0) * k6[i]);
        }
        if (rk45_eval(m, t + h, x5, k7) != fmi3OK) return restore_integration_point(m, x0, t);

        double err_norm = 0.0;
        for (int i = 0; i < N_STATES; i++) {
            x4[i] = x0[i] + h * ((5179.0 / 57600.0) * k1[i]
                                 + (7571.0 / 16695.0) * k3[i]
                                 + (393.0 / 640.0) * k4[i]
                                 - (92097.0 / 339200.0) * k5[i]
                                 + (187.0 / 2100.0) * k6[i]
                                 + (1.0 / 40.0) * k7[i]);
            double scale = RK45_ABS_TOL + m->relative_tolerance * fmax(fabs(x0[i]), fabs(x5[i]));
            double e = (x5[i] - x4[i]) / scale;
            err_norm += e * e;
        }
        err_norm = sqrt(err_norm / (double)N_STATES);

        if (!isfinite(err_norm)) {
            h *= 0.2;
            if (h < RK45_MIN_STEP) {
                return restore_integration_point(m, x0, t);
            }
            continue;
        }

        if (err_norm <= 1.0 || h <= RK45_MIN_STEP) {
#if N_EVENT_INDICATORS > 0
            memcpy(roots_before, m->event_indicators_prev, sizeof(m->event_indicators_prev));
            if (evaluate_event_indicators_at(m, t + h, x5, roots_after) != fmi3OK) {
                return restore_integration_point(m, x0, t);
            }
            if (any_event_indicator_crossed(roots_before, roots_after)) {
                if (process_internal_root(m, t, x0, roots_before, t + h, x5) != fmi3OK) {
                    return restore_integration_point(m, x0, t);
                }
                memcpy(x0, m->x, N_STATES * sizeof(fmi3Float64));
                t = m->time;
                h = fmin(h, t_stop - t);
                continue;
            }
            memcpy(m->event_indicators_prev, roots_after, sizeof(m->event_indicators_prev));
#endif
            memcpy(x0, x5, N_STATES * sizeof(fmi3Float64));
            t += h;

            double factor = err_norm == 0.0 ? 5.0 : 0.9 * pow(err_norm, -0.2);
            if (factor < 0.2) factor = 0.2;
            if (factor > 5.0) factor = 5.0;
            h *= factor;
            if (h > RK45_MAX_STEP) h = RK45_MAX_STEP;
        } else {
            double factor = 0.9 * pow(err_norm, -0.25);
            if (factor < 0.1) factor = 0.1;
            if (factor > 0.5) factor = 0.5;
            h *= factor;
        }
    }

    memcpy(m->x, x0, N_STATES * sizeof(fmi3Float64));
    m->time = t_stop;
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) return fmi3Error;
    return fmi3OK;
#else
    (void)t_start;
    m->time = t_stop;
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) return fmi3Error;
    return fmi3OK;
#endif
}

FMI3_Export fmi3Status fmi3GetOutputDerivatives(
    fmi3Instance instance,
