FMI3_Export fmi3Status fmi3GetClock(
    fmi3Instance instance,
    const fmi3ValueReference valueReferences[], size_t nValueReferences,
    fmi3Boolean values[])
{
#if N_CLOCKS > 0
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || (nValueReferences > 0 && (!valueReferences || !values))) return fmi3Error;
    for (size_t i = 0; i < nValueReferences; i++) {
        fmi3ValueReference vr = valueReferences[i];
        if (vr >= VR_CLK && vr < VR_CLK + N_CLOCKS) {
            values[i] = m->clocks[vr - VR_CLK];
        } else {
            return fmi3Error;
        }
    }
    return fmi3OK;
#else
    (void)instance; (void)valueReferences; (void)nValueReferences; (void)values;
    return fmi3Error;
#endif
}

