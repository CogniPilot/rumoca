FMI3_Export fmi3Status fmi3UpdateDiscreteStates(
    fmi3Instance instance,
    fmi3Boolean* discreteStatesNeedUpdate,
    fmi3Boolean* terminateSimulation,
    fmi3Boolean* nominalsOfContinuousStatesChanged,
    fmi3Boolean* valuesOfContinuousStatesChanged,
    fmi3Boolean* nextEventTimeDefined,
    fmi3Float64* nextEventTime)
{
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || m->state != modelEventMode || !discreteStatesNeedUpdate ||
        !terminateSimulation || !nominalsOfContinuousStatesChanged ||
        !valuesOfContinuousStatesChanged || !nextEventTimeDefined || !nextEventTime) {
        return fmi3Error;
    }

    /* Save pre-values before discrete update */
    memcpy(m->pre_z, m->z, sizeof(m->z));
    memcpy(m->pre_m, m->m, sizeof(m->m));
    snapshot_pre_parameters(m);

#if N_STATES > 0
    fmi3Float64 states_before[N_STATES];
    memcpy(states_before, m->x, sizeof(states_before));
#endif

    /* Evaluate discrete update equations */
    if (iterate_event_discrete_update(m) != fmi3OK) {
        m->state = modelError;
        return fmi3Error;
    }

    *discreteStatesNeedUpdate = 0;
    *terminateSimulation = 0;
    *nominalsOfContinuousStatesChanged = 0;
#if N_STATES > 0
    *valuesOfContinuousStatesChanged = !real_values_equal(states_before, m->x, N_STATES);
#else
    *valuesOfContinuousStatesChanged = 0;
#endif

    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) {
        m->state = modelError;
        return fmi3Error;
    }
    *nextEventTimeDefined = next_time_event(m, nextEventTime);
    if (!*nextEventTimeDefined) *nextEventTime = 0.0;

#if N_CLOCKS > 0
    /* Check periodic clock activation and trigger discrete updates */
    for (int i = 0; i < N_CLOCKS; i++) {
        if (m->clocks[i]) {
            m->clocks[i] = 0;  /* Clear after processing */
        }
    }
#endif

{% if dae.triggered_clock_conditions | default([]) | length > 0 %}
    /* Evaluate triggered clock conditions (FMI 3.0 §2.4.8) */
    {
        const double t = m->time;
        const double time = m->time;
        (void)t; (void)time;
{{ unpack_vars(dae.x, "m->x", pre_array="m->x") }}
{{ unpack_vars(dae.y, "m->y", pre_array="m->y") }}
{{ unpack_vars(dae.w, "m->w", pre_array="m->w") }}
{{ unpack_vars(dae.u, "m->u", pre_array="m->u") }}
{{ unpack_vars(dae.p, "m->p") }}
{{ unpack_vars(dae.constants, "m->constants") }}
{{ unpack_vars(dae.z, "m->z", pre_array="m->pre_z") }}
{{ unpack_vars(dae.m, "m->m", pre_array="m->pre_m") }}
{% for cond in dae.triggered_clock_conditions | default([]) %}
        if ({{ render_expr(cond, cfg) }}) {
            m->clocks[N_PERIODIC_CLOCKS + {{ loop.index0 }}] = 1;
            *discreteStatesNeedUpdate = 1;
        }
{% endfor %}
    }
{% endif %}

    m->is_new_event_iteration = 0;
    m->dirty_values = 1;
    return fmi3OK;
}

FMI3_Export fmi3Status fmi3EnterContinuousTimeMode(fmi3Instance instance) {
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || m->is_co_simulation || m->state != modelEventMode) return fmi3Error;
    m->state = modelContinuousTimeMode;

    /* Save the converged event state for subsequent zero-crossing detection. */
    m->dirty_values = 1;
    compute_derivatives(m);
    if (m->evaluation_error) {
        m->state = modelError;
        return fmi3Error;
    }
    compute_event_indicators(m);
    snapshot_event_indicator_domains(m);
    clear_periodic_relation_memory(m);

    return fmi3OK;
}

