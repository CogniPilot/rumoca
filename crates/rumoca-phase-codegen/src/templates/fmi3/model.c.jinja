    for (size_t i = 0; i < nValueReferences; i++) {
        fmi3ValueReference vr = valueReferences[i];
        if (vr >= VR_CLK && vr < VR_CLK + N_CLOCKS) {
            m->clocks[vr - VR_CLK] = values[i];
