static double event_right_limit_time(double event_time) {
    double scale = 1.0 + fabs(event_time);
    double stepped = event_time + fmax(1.0e-6 * scale, 2.220446049250313e-16 * scale);
    double adjacent = nextafter(event_time, INFINITY);
    return stepped > adjacent ? stepped : adjacent;
}

static int event_indicator_crossed(double previous, double current) {
    return (previous < 0.0 && current >= 0.0) || (previous > 0.0 && current <= 0.0);
}

static double root_relation_memory_value(double previous, double current) {
    if (current < 0.0) return 1.0;
    if (current > 0.0) return 0.0;
    if (previous > 0.0) return 1.0;
    return 0.0;
}

static int scheduled_time_event_active(double time) {
{% if dae.scheduled_time_events | default([]) | length > 0 %}
    static const double scheduled_events[] = {
{% for t_event in dae.scheduled_time_events | default([]) %}
        {{ t_event }}{{ "," if not loop.last else "" }}
{% endfor %}
    };
    static const int n_scheduled = {{ dae.scheduled_time_events | default([]) | length }};
    for (int i = 0; i < n_scheduled; i++) {
        double tol = 1.0e-12 * (1.0 + fabs(scheduled_events[i]));
        if (fabs(time - scheduled_events[i]) <= tol) return 1;
    }
{% else %}
    (void)time;
{% endif %}
    return 0;
}

static void compute_event_discrete_updates(ModelInstance* m) {
    double saved_time = m->time;
    if (m->root_event_pending || scheduled_time_event_active(m->time)) {
        m->time = event_right_limit_time(m->time);
    }
    compute_discrete_updates(m, 1);
    m->time = saved_time;
}

