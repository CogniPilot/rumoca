FMI3_EXPORT fmi3Status fmi3GetFloat64(
    fmi3Instance instance,
    const fmi3ValueReference valueReferences[], size_t nValueReferences,
    fmi3Float64 values[], size_t nValues)
{
    ModelInstance* m = (ModelInstance*)instance;
    (void)nValues;

    if (m->dirty_values) {
        compute_derivatives(m);
        compute_outputs(m);
        m->dirty_values = 0;
    }

    size_t val_idx = 0;
    for (size_t i = 0; i < nValueReferences; i++) {
        int count;
        fmi3Status s = get_float64_by_vr(m, valueReferences[i], &values[val_idx], &count);
        if (s != fmi3OK) return s;
        val_idx += count;
    }
    return fmi3OK;
}

FMI3_EXPORT fmi3Status fmi3SetFloat64(
    fmi3Instance instance,
    const fmi3ValueReference valueReferences[], size_t nValueReferences,
    const fmi3Float64 values[], size_t nValues)
{
    ModelInstance* m = (ModelInstance*)instance;
    (void)nValues;

    size_t val_idx = 0;
    for (size_t i = 0; i < nValueReferences; i++) {
        int count;
        fmi3Status s = set_float64_by_vr(m, valueReferences[i], &values[val_idx], &count);
        if (s != fmi3OK) return s;
        val_idx += count;
    }
    m->dirty_values = 1;
    return fmi3OK;
}

FMI3_EXPORT fmi3Status fmi3GetFloat32(fmi3Instance instance, const fmi3ValueReference vr[], size_t nvr, fmi3Float32 value[], size_t nValues) {
    /* Delegate to Float64 with lossy downcast */
    ModelInstance* m = (ModelInstance*)instance;
    (void)nValues;
    if (m->dirty_values) {
        compute_derivatives(m);
        compute_outputs(m);
        m->dirty_values = 0;
    }
    size_t val_idx = 0;
    for (size_t i = 0; i < nvr; i++) {
        fmi3Float64 tmp[N_REALS > 0 ? N_REALS : 1];
        int count;
        fmi3Status s = get_float64_by_vr(m, vr[i], tmp, &count);
        if (s != fmi3OK) return s;
        for (int j = 0; j < count; j++) value[val_idx++] = (fmi3Float32)tmp[j];
    }
    return fmi3OK;
}

FMI3_EXPORT fmi3Status fmi3SetFloat32(fmi3Instance instance, const fmi3ValueReference vr[], size_t nvr, const fmi3Float32 value[], size_t nValues) {
    /* Delegate to Float64 with promotion */
    ModelInstance* m = (ModelInstance*)instance;
    (void)nValues;
    size_t val_idx = 0;
    for (size_t i = 0; i < nvr; i++) {
        int count = vr_scalar_count(vr[i]);
        fmi3Float64 tmp[N_REALS > 0 ? N_REALS : 1];
        for (int j = 0; j < count; j++) tmp[j] = (fmi3Float64)value[val_idx++];
        int dummy;
        fmi3Status s = set_float64_by_vr(m, vr[i], tmp, &dummy);
        if (s != fmi3OK) return s;
    }
    return fmi3OK;
}

