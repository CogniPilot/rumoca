FMI3_Export fmi3Status fmi3GetFMUState(fmi3Instance instance, fmi3FMUState* FMUState) {
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || !FMUState) return fmi3Error;
    ModelInstance* copy = (ModelInstance*)malloc(sizeof(ModelInstance));
    if (!copy) return fmi3Error;
    memcpy(copy, m, sizeof(ModelInstance));
    copy->instance_name = NULL;
    copy->instantiation_token = NULL;
    copy->instance_environment = NULL;
    copy->intermediateUpdate = NULL;
    *FMUState = (fmi3FMUState)copy;
    return fmi3OK;
}

FMI3_Export fmi3Status fmi3SetFMUState(fmi3Instance instance, fmi3FMUState FMUState) {
    ModelInstance* m = (ModelInstance*)instance;
    if (!m || !FMUState) return fmi3Error;
    const fmi3String instance_name = m->instance_name;
    const fmi3String instantiation_token = m->instantiation_token;
    const fmi3InstanceEnvironment instance_environment = m->instance_environment;
    fmi3IntermediateUpdateCallback const intermediate_update = m->intermediateUpdate;
    const fmi3Boolean is_co_simulation = m->is_co_simulation;
    const fmi3Boolean event_mode_used = m->event_mode_used;
    const fmi3Boolean early_return_allowed = m->early_return_allowed;
    const ModelInstance* saved = (const ModelInstance*)FMUState;
    if (saved->is_co_simulation != is_co_simulation ||
        saved->event_mode_used != event_mode_used ||
        saved->early_return_allowed != early_return_allowed) {
        return fmi3Error;
    }
    memcpy(m, (ModelInstance*)FMUState, sizeof(ModelInstance));
    m->instance_name = instance_name;
    m->instantiation_token = instantiation_token;
    m->instance_environment = instance_environment;
    m->intermediateUpdate = intermediate_update;
    m->is_co_simulation = is_co_simulation;
    m->event_mode_used = event_mode_used;
    m->early_return_allowed = early_return_allowed;
    m->dirty_values = 1;
    return fmi3OK;
}

FMI3_Export fmi3Status fmi3FreeFMUState(fmi3Instance instance, fmi3FMUState* FMUState) {
    if (!instance || !FMUState) return fmi3Error;
    if (*FMUState) {
        free(*FMUState);
