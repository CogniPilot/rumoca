within;
function quad_deriv13
  input Real X[13]; input Real tt; input Real tg[300]; input Real Xref[300,10];
  input Real nref[300,6]; input Real aref[300,3]; input Real BK[9,9]; input Real g; input Real Kw;
  output Real Xdot[13];
protected
  Integer i; Integer cnt; Real w; Real Xbar[10]; Real nbar[6]; Real alpha_ref[3];
  Real qn[4]; Real qnsq; Real Xn[10]; Real xi[9]; Real nt[9];
  Real a_b[3]; Real omega_cmd[3]; Real R[3,3]; Real qd[4];
algorithm
  cnt := 0;
  for k in 1:300 loop
    cnt := cnt + (if tt > tg[k] then 1 else 0);
  end for;
  i := max(2, min(300, cnt + 1));
  w := (tt - tg[i-1]) / (tg[i] - tg[i-1]);
  for j in 1:10 loop Xbar[j] := (1.0-w)*Xref[i-1,j] + w*Xref[i,j]; end for;
  for j in 1:6  loop nbar[j] := (1.0-w)*nref[i-1,j] + w*nref[i,j]; end for;
  for j in 1:3  loop alpha_ref[j] := (1.0-w)*aref[i-1,j] + w*aref[i,j]; end for;
  qnsq := X[7]^2+X[8]^2+X[9]^2+X[10]^2;
  qn := X[7:10]/sqrt(qnsq);
  Xn := {X[1],X[2],X[3],X[4],X[5],X[6], qn[1],qn[2],qn[3],qn[4]};
  xi := LieGroups.SE23.Quat.log_map(LieGroups.SE23.Quat.product(LieGroups.SE23.Quat.inverse(Xn), Xbar));
  nt := LieGroups.SE23.Quat.left_jacobian(xi)*(BK*xi);
  a_b := {0.0,0.0, nbar[3]-nt[6]};
  omega_cmd := {nbar[4]-nt[7], nbar[5]-nt[8], nbar[6]-nt[9]};
  R := LieGroups.SO3.Quat.to_DCM(qn);
  qd := LieGroups.SO3.Quat.kinematics(qn, X[11:13]);
  Xdot[1]:=X[4]; Xdot[2]:=X[5]; Xdot[3]:=X[6];
  Xdot[4]:=R[1,1]*a_b[1]+R[1,2]*a_b[2]+R[1,3]*a_b[3];
  Xdot[5]:=R[2,1]*a_b[1]+R[2,2]*a_b[2]+R[2,3]*a_b[3];
  Xdot[6]:=R[3,1]*a_b[1]+R[3,2]*a_b[2]+R[3,3]*a_b[3] + g;
  Xdot[7]:=qd[1]+1.0*(1.0-qnsq)*X[7]; Xdot[8]:=qd[2]+1.0*(1.0-qnsq)*X[8];
  Xdot[9]:=qd[3]+1.0*(1.0-qnsq)*X[9]; Xdot[10]:=qd[4]+1.0*(1.0-qnsq)*X[10];
  Xdot[11]:=alpha_ref[1]-Kw*(X[11]-omega_cmd[1]);
  Xdot[12]:=alpha_ref[2]-Kw*(X[12]-omega_cmd[2]);
  Xdot[13]:=alpha_ref[3]-Kw*(X[13]-omega_cmd[3]);
end quad_deriv13;

